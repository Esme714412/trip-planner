import React, { useState, useMemo, useEffect, useRef } from 'react';
import {
  doc, updateDoc, serverTimestamp, setDoc,
  getDocs, getDoc, collection, query, where, onSnapshot,
} from 'firebase/firestore';
import { db } from '../firebase/config';
import {
  MapPin, Clock, Globe, ShoppingBag, Ticket, Navigation,
  Car, Plus, Edit2, Trash2, DollarSign, Download,
  ChevronDown, ChevronUp, Check, X, Users,
  ListTodo, Calendar, Settings, Lock, Unlock, Tag, Save,
  Star, Plane, Luggage, Camera as CameraIcon,
  ArrowLeft, ArrowRight, Share2, WifiOff, Zap,
  MoveRight, Hotel, MoreHorizontal, Wallet, Map, CheckSquare,
} from 'lucide-react';
import ExpenseFormModal from './ExpenseFormModal';
import { useConfirm } from './ConfirmModal';

// ─── 常數 ────────────────────────────────────────────────────────────────────
const TRIP_ICONS   = [Plane, MapPin, Luggage, CameraIcon];
const TRIP_EMOJIS  = ['✈️', '🗺️', '🎒', '📸'];
const ACCOM_COLORS = ['teal','violet','rose','amber','sky','lime'];

// ─── Hooks & Utils ────────────────────────────────────────────────────────────
function useDebounce(value, delay) {
  const [dv, setDv] = useState(value);
  useEffect(() => {
    const t = setTimeout(() => setDv(value), delay);
    return () => clearTimeout(t);
  }, [value, delay]);
  return dv;
}

function calcSettlement(userStats) {
  const balances  = Object.entries(userStats).map(([name, s]) => ({ name, balance: Math.round(s.paid - s.consumed) }));
  const creditors = balances.filter(b => b.balance > 0).map(b => ({ ...b }));
  const debtors   = balances.filter(b => b.balance < 0).map(b => ({ ...b, balance: Math.abs(b.balance) }));
  const result = [];
  let ci = 0, di = 0;
  while (ci < creditors.length && di < debtors.length) {
    const amount = Math.min(creditors[ci].balance, debtors[di].balance);
    if (amount > 0) result.push({ from: debtors[di].name, to: creditors[ci].name, amount });
    creditors[ci].balance -= amount;
    debtors[di].balance   -= amount;
    if (creditors[ci].balance === 0) ci++;
    if (debtors[di].balance   === 0) di++;
  }
  return result;
}

function getDatesInRange(start, end) {
  if (!start || !end) return [];
  const dates = [];
  const cur  = new Date(start);
  const last = new Date(end);
  while (cur <= last) {
    dates.push(cur.toISOString().split('T')[0]);
    cur.setDate(cur.getDate() + 1);
  }
  return dates;
}

function normalizeTransportSegments(item) {
  if (item.transportSegments?.length > 0) return item.transportSegments;
  if (item.transport || item.transportDeparture || item.transportDuration || item.transportPrice || item.transportUrl) {
    return [{ id: crypto.randomUUID(), mode: item.transport||'', departure: item.transportDeparture||'', duration: item.transportDuration||'', price: item.transportPrice||'', url: item.transportUrl||'', needTicket: item.transportNeedTicket||false }];
  }
  return [];
}

function emptySegment() {
  return { id: crypto.randomUUID(), mode:'', departure:'', duration:'', price:'', url:'', needTicket:false };
}

function cleanForFirestore(obj) {
  if (Array.isArray(obj)) return obj.map(cleanForFirestore);
  if (obj !== null && typeof obj === 'object') {
    return Object.fromEntries(
      Object.entries(obj)
        .filter(([, v]) => v !== undefined)
        .map(([k, v]) => [k, cleanForFirestore(v)])
    );
  }
  return obj;
}

function parseMarkdown(mdText) {
  const lines = mdText.split('\n');
  const itineraryItems = [];
  const checklistItems = [];
  let currentDate = '';
  let currentItem = null;
  let inChecklist = false;
  let inTodo = false;
  let inShopping = false;

  const flushItem = () => {
    if (currentItem?.title) {
      if (currentItem.transportNeedTicket)
        checklistItems.push({ id: crypto.randomUUID(), text: `購票：${currentItem.title}`, checked: false, autoAdded: true });
      itineraryItems.push({ ...currentItem, id: crypto.randomUUID() });
    }
    currentItem = null; inTodo = false; inShopping = false;
  };

  for (const raw of lines) {
    const trimmed = raw.trim();
    if (trimmed.startsWith('## ')) {
      flushItem();
      const dateMatch = trimmed.match(/(\d{4}-\d{2}-\d{2})/);
      if (dateMatch) { currentDate = dateMatch[1]; inChecklist = false; }
      else if (trimmed.includes('清單') || trimmed.includes('checklist')) { inChecklist = true; }
      continue;
    }
    if (inChecklist) {
      if (trimmed.match(/^-\s*\[( |x|X)\]\s+/)) {
        const checked = trimmed.match(/^-\s*\[x\]/i) !== null;
        const text = trimmed.replace(/^-\s*\[[ xX]\]\s*/, '').trim();
        if (text) checklistItems.push({ id: crypto.randomUUID(), text, checked });
      }
      continue;
    }
    if (trimmed.startsWith('- time:') || trimmed.startsWith('- title:')) {
      flushItem();
      currentItem = { date: currentDate, time:'', title:'', location:'', transport:'', transportDeparture:'', transportDuration:'', transportPrice:'', transportUrl:'', transportNeedTicket:false, notes:'', website:'', hours:'', tickets:'', shoppingList:[], todoList:[] };
      inTodo = false; inShopping = false;
    }
    if (!currentItem) continue;
    const kvMatch = trimmed.match(/^-?\s*(\w+):\s*(.*)/);
    if (kvMatch) {
      const [, key, val] = kvMatch;
      const v = val.trim();
      const map = { time:'time', title:'title', location:'location', transport:'transport', transport_departure:'transportDeparture', transport_duration:'transportDuration', transport_price:'transportPrice', transport_url:'transportUrl', hours:'hours', website:'website', notes:'notes', tickets:'tickets' };
      if (map[key]) currentItem[map[key]] = v;
      else if (key === 'transport_ticket') currentItem.transportNeedTicket = v === 'true';
      else if (key === 'todo')     { inTodo = true;  inShopping = false; }
      else if (key === 'shopping') { inShopping = true; inTodo = false; }
    } else if (trimmed.startsWith('- ') && currentItem) {
      const text = trimmed.replace(/^-\s+/, '').trim();
      if (inTodo && text)     currentItem.todoList     = [...(currentItem.todoList||[]),     { id: crypto.randomUUID(), text, checked: false }];
      else if (inShopping && text) currentItem.shoppingList = [...(currentItem.shoppingList||[]), { id: crypto.randomUUID(), text, checked: false }];
    }
  }
  flushItem();
  return { itineraryItems, checklistItems };
}

// ─── Main Component ───────────────────────────────────────────────────────────
export default function TripApp({ uid, currentUserUid, currentUserName, tripId, initialData, readOnly = false, onBack }) {
  const { confirm, ConfirmUI } = useConfirm();
  const isOwner = uid === currentUserUid;

  // ── Core state ──────────────────────────────────────────────────────────────
  const [tripName,       setTripName]       = useState(initialData.name          || '新旅程');
  const [tripIconIndex,  setTripIconIndex]  = useState(initialData.iconIndex     ?? 0);
  const [tripStartDate,  setTripStartDate]  = useState(initialData.tripStartDate || '');
  const [tripEndDate,    setTripEndDate]    = useState(initialData.tripEndDate   || '');
  const [users,          setUsers]          = useState(initialData.users         || ['自己']);
  const [rates,          setRates]          = useState(initialData.rates         || { TWD:1, JPY:0.21, USD:31.5 });
  const [baseCurrency,   setBaseCurrency]   = useState(initialData.baseCurrency  || 'TWD');
  const [categories,     setCategories]     = useState(initialData.categories    || ['飲食','交通','住宿','購物','娛樂','門票','其他']);
  const [checklist,      setChecklist]      = useState(initialData.checklist     || []);
  const [itinerary,      setItinerary]      = useState(initialData.itinerary     || []);
  const [expenses,       setExpenses]       = useState(initialData.expenses      || []);
  const [flexTodos,      setFlexTodos]      = useState(initialData.flexTodos     || []);
  const [accommodations, setAccommodations] = useState(initialData.accommodations|| []);
  const [savedSpots,     setSavedSpots]     = useState(initialData.savedSpots    || []);

  // ── UI state ────────────────────────────────────────────────────────────────
  const [mode,             setMode]             = useState('checklist');
  const [listTab,          setListTab]          = useState('pretrip');
  const [isEditMode,       setIsEditMode]       = useState(false);
  const [expandedItems,    setExpandedItems]    = useState(new Set());
  const [isSettingsOpen,   setIsSettingsOpen]   = useState(false);
  const [isEditModalOpen,  setIsEditModalOpen]  = useState(false);
  const [showDoneTickets,  setShowDoneTickets]  = useState(false);
  const [showDoneRegular,  setShowDoneRegular]  = useState(false);
  const [editingItem,      setEditingItem]      = useState(null);
  const [addingExpenseFor, setAddingExpenseFor] = useState(null);
  const [editingExpense,   setEditingExpense]   = useState(null);
  const [isEditingName,    setIsEditingName]    = useState(false);
  const [saveStatus,       setSaveStatus]       = useState('saved');
  const [toast,            setToast]            = useState('');
  const [isEditingDates,   setIsEditingDates]   = useState(false);
  const [flexCollapsed,    setFlexCollapsed]    = useState(false);
  const [expandedTransport,setExpandedTransport]= useState(new Set());
  const [isOptionalOpen,   setIsOptionalOpen]   = useState(false);
  const [isOnline,         setIsOnline]         = useState(navigator.onLine);
  const [showScrollTop,    setShowScrollTop]    = useState(false);
  const [selectedDay,      setSelectedDay]      = useState(0);
  const [movingId,         setMovingId]         = useState(null);

  // Accommodate add state
  const [showAddAccom, setShowAddAccom] = useState(false);
  const [newAccomDate, setNewAccomDate] = useState('');
  const [newAccomName, setNewAccomName] = useState('');
  const [newAccomLoc,  setNewAccomLoc]  = useState('');

  // Spot state
  const [savedSpotName,    setSavedSpotName]    = useState('');
  const [savedSpotNote,    setSavedSpotNote]    = useState('');
  const [savedSpotUrl,     setSavedSpotUrl]     = useState('');
  const [expandedSpotId,   setExpandedSpotId]   = useState(null);
  const [addingSpotToDate, setAddingSpotToDate] = useState(null);

  // Settings state
  const [isUsersLocked,   setIsUsersLocked]   = useState(true);
  const [newUser,          setNewUser]          = useState('');
  const [newCategory,      setNewCategory]      = useState('');
  const [newCurrency,      setNewCurrency]      = useState('');
  const [newRateValue,     setNewRateValue]     = useState('');
  const [editingUserId,    setEditingUserId]    = useState(null);
  const [editUserValue,    setEditUserValue]    = useState('');
  const [editingCatId,     setEditingCatId]     = useState(null);
  const [editCatValue,     setEditCatValue]     = useState('');
  const [newChecklistItem, setNewChecklistItem] = useState('');
  const [globalShopDate,   setGlobalShopDate]   = useState('');
  const [globalShopId,     setGlobalShopId]     = useState('');
  const [globalNewShop,    setGlobalNewShop]    = useState('');
  const [modalNewShop,     setModalNewShop]     = useState('');

  // Share state
  const [isShareOpen,   setIsShareOpen]   = useState(false);
  const [shareEditors,  setShareEditors]  = useState(initialData.editors  || []);
  const [shareViewers,  setShareViewers]  = useState(initialData.viewers  || []);
  const [newShareEmail, setNewShareEmail] = useState('');
  const [newShareRole,  setNewShareRole]  = useState('viewer');
  const [shareStatus,   setShareStatus]   = useState('');
  const [shareEmailMap, setShareEmailMap] = useState({});

  // Markdown
  const [isMarkdownImportOpen, setIsMarkdownImportOpen] = useState(false);
  const [markdownText,         setMarkdownText]         = useState('');
  const [markdownStatus,       setMarkdownStatus]       = useState('');

  const tripNameRef = useRef(null);
  const TripIcon    = TRIP_ICONS[tripIconIndex % TRIP_ICONS.length];

  const showToast = (msg) => { setToast(msg); setTimeout(() => setToast(''), 2000); };

  useEffect(() => { if (isEditingName) tripNameRef.current?.focus(); }, [isEditingName]);

  useEffect(() => {
    const on = () => setIsOnline(true), off = () => setIsOnline(false);
    window.addEventListener('online', on); window.addEventListener('offline', off);
    return () => { window.removeEventListener('online', on); window.removeEventListener('offline', off); };
  }, []);

  useEffect(() => {
    const h = () => setShowScrollTop(window.scrollY > 300);
    window.addEventListener('scroll', h, { passive: true });
    return () => window.removeEventListener('scroll', h);
  }, []);

  // Share member emails
  useEffect(() => {
    const allUids = [...(initialData.editors || []), ...(initialData.viewers || [])];
    if (!allUids.length) return;
    (async () => {
      const map = {};
      for (const targetUid of allUids) {
        try {
          const snap = await getDoc(doc(db, 'userProfiles', targetUid));
          if (snap.exists()) map[targetUid] = snap.data().email || targetUid;
        } catch { /* ignore */ }
      }
      setShareEmailMap(map);
    })();
  }, []); // eslint-disable-line

  // ── Auto-save ───────────────────────────────────────────────────────────────
  const payload = useMemo(() => ({
    name: tripName, iconIndex: tripIconIndex, tripStartDate, tripEndDate,
    users, rates, baseCurrency, categories, checklist, itinerary, expenses,
    flexTodos, accommodations, savedSpots,
  }), [tripName, tripIconIndex, tripStartDate, tripEndDate, users, rates, baseCurrency, categories, checklist, itinerary, expenses, flexTodos, accommodations, savedSpots]);

  const debouncedPayload = useDebounce(payload, 1200);
  const isFirstSave = useRef(true);

  useEffect(() => {
    if (isFirstSave.current) { isFirstSave.current = false; return; }
    if (readOnly) return;
    setSaveStatus('saving');
    updateDoc(doc(db, 'users', uid, 'trips', tripId), cleanForFirestore({ ...debouncedPayload, updatedAt: serverTimestamp() }))
      .then(() => setSaveStatus('saved'))
      .catch(() => setSaveStatus('error'));
  }, [debouncedPayload, uid, tripId, readOnly]);

  const lastLocalSaveTime = useRef(0);
  useEffect(() => {
    const unsub = onSnapshot(doc(db, 'users', uid, 'trips', tripId), (snap) => {
      if (!snap.exists()) return;
      if (Date.now() - lastLocalSaveTime.current < 3000) return;
      const remoteExpenses = snap.data().expenses;
      if (remoteExpenses) setExpenses(remoteExpenses);
    });
    return () => unsub();
  }, [uid, tripId]);

  // ── Date helpers ─────────────────────────────────────────────────────────────
  const fmtDate = (dateStr) => {
    if (!dateStr) return '未定日期';
    const d = new Date(dateStr);
    if (isNaN(d.getTime())) return dateStr;
    return `${d.getMonth()+1}/${d.getDate()}(${'日一二三四五六'[d.getDay()]})`;
  };
  const fmtShort = (dateStr) => {
    if (!dateStr) return '';
    const d = new Date(dateStr);
    return `${d.getMonth()+1}/${d.getDate()}`;
  };
  const tripDayLabel = (dateStr) => {
    if (!tripStartDate || !dateStr) return fmtDate(dateStr);
    const start = new Date(tripStartDate), target = new Date(dateStr);
    const dayN = Math.round((target - start) / (1000*60*60*24)) + 1;
    return dayN < 1 ? fmtDate(dateStr) : `第 ${dayN} 天　${fmtDate(dateStr)}`;
  };
  const tripDateRange = useMemo(() => getDatesInRange(tripStartDate, tripEndDate), [tripStartDate, tripEndDate]);

  // ── Itinerary handlers ───────────────────────────────────────────────────────
  const sortByTime = () => setItinerary([...itinerary].sort((a,b) => {
    const da = a.date||'9999', db2 = b.date||'9999';
    return da !== db2 ? da.localeCompare(db2) : (a.time||'').localeCompare(b.time||'');
  }));

  const handleTapMove = (targetId) => {
    if (!movingId) return;
    if (movingId === targetId) { setMovingId(null); return; }
    setItinerary(prev => {
      const arr = [...prev];
      const fromIdx = arr.findIndex(i => i.id === movingId);
      const toIdx   = arr.findIndex(i => i.id === targetId);
      if (fromIdx === -1 || toIdx === -1) return prev;
      const item = { ...arr[fromIdx], date: arr[toIdx].date };
      arr.splice(fromIdx, 1);
      const newTo = arr.findIndex(i => i.id === targetId);
      arr.splice(newTo, 0, item);
      return arr;
    });
    setMovingId(null);
  };

  const saveItineraryItem = (item) => {
    const type = item.type || 'place';
    let withMeta;
    if (type === 'transport') {
      withMeta = { ...item, type:'transport', lastEditedBy: currentUserName||'未知', lastEditedAt: new Date().toISOString() };
    } else {
      const segments = item.transportSegments || [];
      withMeta = {
        ...item, type:'place', transportSegments: segments,
        transport: segments[0]?.mode||'', transportDeparture: segments[0]?.departure||'',
        transportDuration: segments[0]?.duration||'', transportPrice: segments[0]?.price||'',
        transportUrl: segments[0]?.url||'', transportNeedTicket: segments[0]?.needTicket||false,
        lastEditedBy: currentUserName||'未知', lastEditedAt: new Date().toISOString(),
      };
    }
    if (item.id) setItinerary(itinerary.map(i => i.id === item.id ? withMeta : i));
    else         setItinerary([...itinerary, { ...withMeta, id: crypto.randomUUID() }]);
    setIsEditModalOpen(false); setModalNewShop(''); setIsOptionalOpen(false);
  };

  const deleteItineraryItem = async (id) => {
    if (await confirm('確定要刪除這個行程嗎？')) setItinerary(itinerary.filter(i => i.id !== id));
  };

  // ── Checklist handlers ───────────────────────────────────────────────────────
  const toggleChecklist = (id) => setChecklist(checklist.map(i => i.id === id ? { ...i, checked: !i.checked } : i));
  const addChecklistItem = () => {
    if (!newChecklistItem.trim()) return;
    setChecklist([...checklist, { id: crypto.randomUUID(), text: newChecklistItem, checked: false }]);
    setNewChecklistItem('');
  };
  const deleteChecklistItem = async (id) => {
    if (await confirm('刪除此清單項目？', '確認刪除')) setChecklist(checklist.filter(i => i.id !== id));
  };

  // ── Shopping handlers ────────────────────────────────────────────────────────
  const toggleShop    = (iId, sId) => setItinerary(itinerary.map(i => i.id===iId ? { ...i, shoppingList:(i.shoppingList||[]).map(s=>s.id===sId?{...s,checked:!s.checked}:s) } : i));
  const addModalShop  = () => { if (!modalNewShop.trim()) return; setEditingItem(prev => ({ ...prev, shoppingList:[...(prev.shoppingList||[]),{id:crypto.randomUUID(),text:modalNewShop,checked:false}] })); setModalNewShop(''); };
  const delModalShop  = (sId) => setEditingItem(prev => ({ ...prev, shoppingList:(prev.shoppingList||[]).filter(s=>s.id!==sId) }));
  const addGlobalShop = () => {
    if (!globalShopId || !globalNewShop.trim()) return;
    setItinerary(itinerary.map(i=>i.id===globalShopId ? { ...i, shoppingList:[...(i.shoppingList||[]),{id:crypto.randomUUID(),text:globalNewShop,checked:false}] } : i));
    setGlobalNewShop('');
  };
  const delGlobalShop = async (iId, sId) => {
    if (await confirm('刪除此購物項目？','確認刪除'))
      setItinerary(itinerary.map(i=>i.id===iId ? { ...i, shoppingList:(i.shoppingList||[]).filter(s=>s.id!==sId) } : i));
  };

  // ── Users ────────────────────────────────────────────────────────────────────
  const addUser = () => {
    if (newUser.trim() && !users.includes(newUser.trim())) { setUsers([...users, newUser.trim()]); setNewUser(''); }
  };
  const saveEditedUser = (old) => {
    const nw = editUserValue.trim();
    if (!nw||nw===old) { setEditingUserId(null); return; }
    if (users.includes(nw)) { alert('此名稱已存在！'); return; }
    setUsers(users.map(u=>u===old?nw:u));
    setExpenses(expenses.map(exp => {
      let e = { ...exp };
      if (e.paidBy===old) e.paidBy=nw;
      e.splitAmong = (e.splitAmong||[]).map(u=>u===old?nw:u);
      if (e.customSplit?.[old]!==undefined) { const v=e.customSplit[old]; const cs={...e.customSplit}; delete cs[old]; cs[nw]=v; e.customSplit=cs; }
      return e;
    }));
    setEditingUserId(null);
  };
  const removeUser = async (u, idx) => {
    if (idx===0) { alert('建立者不可被刪除'); return; }
    if (users.length<=1) { alert('至少需要保留一位成員'); return; }
    if (!isOwner) { alert('只有行程擁有者可以刪除成員'); return; }
    if (!await confirm(`刪除「${u}」？\n系統將重新分配其相關花費。`, '確認刪除')) return;
    const remaining = users.filter(x=>x!==u);
    setUsers(remaining);
    setExpenses(expenses.map(exp => {
      let e = { ...exp };
      if (e.paidBy===u) e.paidBy=remaining[0]||'';
      if (e.splitMode==='custom'&&e.customSplit?.[u]!==undefined) {
        const amt=Number(e.customSplit[u])||0; const cs={...e.customSplit}; delete cs[u];
        if (amt>0&&cs[e.paidBy]!==undefined) cs[e.paidBy]=(Number(cs[e.paidBy])||0)+amt;
        e.customSplit=cs;
      } else if (e.splitMode==='equal') { e.splitAmong=(e.splitAmong||[]).filter(x=>x!==u); }
      return e;
    }));
  };

  // ── Categories ───────────────────────────────────────────────────────────────
  const addCategory   = () => { if (newCategory.trim()&&!categories.includes(newCategory.trim())) { setCategories([...categories,newCategory.trim()]); setNewCategory(''); } };
  const saveEditedCat = (old) => {
    const nw=editCatValue.trim();
    if (!nw||nw===old) { setEditingCatId(null); return; }
    if (categories.includes(nw)) { alert('此分類已存在！'); return; }
    setCategories(categories.map(c=>c===old?nw:c));
    setExpenses(expenses.map(e=>e.category===old?{...e,category:nw}:e));
    setEditingCatId(null);
  };
  const removeCat = (c) => setCategories(categories.filter(x=>x!==c));

  // ── Rates ────────────────────────────────────────────────────────────────────
  const addRate    = () => { if(newCurrency.trim()&&newRateValue) { setRates({...rates,[newCurrency.trim().toUpperCase()]:parseFloat(newRateValue)}); setNewCurrency(''); setNewRateValue(''); } };
  const updateRate = (c,v) => { if(v) setRates({...rates,[c]:parseFloat(v)}); };
  const removeRate = async (c) => {
    if (c===baseCurrency) { alert('基準幣別不可刪除'); return; }
    if (await confirm(`刪除 ${c}？`,'確認刪除')) { const r={...rates}; delete r[c]; setRates(r); }
  };

  // ── Expenses ─────────────────────────────────────────────────────────────────
  const saveExpense = (exp) => {
    lastLocalSaveTime.current = Date.now();
    const clean = cleanForFirestore(exp);
    if (clean.id) setExpenses(expenses.map(e=>e.id===clean.id?clean:e));
    else          setExpenses([...expenses,{...clean,id:crypto.randomUUID()}]);
    setAddingExpenseFor(null); setEditingExpense(null);
    showToast(clean.id ? '✅ 已更新帳務' : '✅ 已記帳');
  };
  const deleteExpense = async (id) => {
    if (await confirm('確定刪除此筆紀錄？','確認刪除')) {
      lastLocalSaveTime.current = Date.now();
      setExpenses(expenses.filter(e=>e.id!==id));
      showToast('🗑 已刪除');
    }
  };

  // ── Finance calcs ─────────────────────────────────────────────────────────────
  const convertedExpenses = useMemo(() => expenses.map(exp => {
    const expRate=rates[exp.currency]||1, baseRate=rates[baseCurrency]||1;
    const baseAmount=(exp.amount*expRate)/baseRate;
    return { ...exp, baseAmount, rateUsed: expRate/baseRate };
  }), [expenses, rates, baseCurrency]);

  const financeSummary = useMemo(() => {
    let total = 0;
    const userStats = users.reduce((acc,u) => ({ ...acc, [u]:{paid:0,consumed:0} }), {});
    convertedExpenses.forEach(exp => {
      if (exp.splitMode==='aa') {
        const perPerson = exp.baseAmount;
        (exp.aaSplitAmong||exp.splitAmong||[]).forEach(u => { if(userStats[u]) { userStats[u].paid+=perPerson; userStats[u].consumed+=perPerson; } });
        total += perPerson*(exp.aaSplitAmong||exp.splitAmong||[]).length;
      } else {
        total += exp.baseAmount;
        if (userStats[exp.paidBy]) userStats[exp.paidBy].paid+=exp.baseAmount;
        if (exp.splitMode==='custom'&&exp.customSplit) {
          Object.entries(exp.customSplit).forEach(([u,amt]) => { if(userStats[u]) userStats[u].consumed+=Number(amt)*exp.rateUsed; });
        } else {
          const cnt=exp.splitAmong?.length||0;
          if (cnt>0) { const pp=exp.baseAmount/cnt; (exp.splitAmong||[]).forEach(u => { if(userStats[u]) userStats[u].consumed+=pp; }); }
        }
      }
    });
    return { total, userStats };
  }, [convertedExpenses, users]);

  const settlement = useMemo(() => calcSettlement(financeSummary.userStats), [financeSummary]);

  // ── Export CSV ────────────────────────────────────────────────────────────────
  const exportCSV = () => {
    const tripDateInfo = tripStartDate&&tripEndDate ? `${tripStartDate} ~ ${tripEndDate}` : tripStartDate||'未設定';
    let csv = `\uFEFF旅程名稱,${tripName}\n旅行日期,${tripDateInfo}\n基準幣別,${baseCurrency}\n\n`;
    csv += '日期/時間,關聯行程,分類,描述,原始金額,幣別,換算金額('+baseCurrency+'),付款人,' + users.map(u=>`[${u}]需付(${baseCurrency})`).join(',') + '\n';
    expenses.forEach(exp => {
      const rel = itinerary.find(i=>i.id===exp.itineraryId);
      const expRate=rates[exp.currency]||1, baseRate=rates[baseCurrency]||1;
      const converted=((exp.amount*expRate)/baseRate).toFixed(2);
      const splits=users.map(u => {
        if(exp.splitMode==='custom') return ((exp.customSplit?.[u]||0)*(expRate/baseRate)).toFixed(2);
        if((exp.splitAmong||[]).includes(u)) return (((exp.amount/(exp.splitAmong.length||1))*expRate/baseRate).toFixed(2));
        return '0';
      });
      const row=[rel?`${rel.date} ${rel.time}`:'無',rel?rel.title:'無',exp.category||'其他',exp.description,exp.amount,exp.currency,converted,exp.paidBy,...splits].map(f=>`"${String(f).replace(/"/g,'""')}"`).join(',');
      csv+=row+'\n';
    });
    const a=document.createElement('a');
    a.href=URL.createObjectURL(new Blob([csv],{type:'text/csv;charset=utf-8;'}));
    a.download=`${tripName}-花費明細.csv`;
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
  };

  // ── Markdown import ───────────────────────────────────────────────────────────
  const handleMarkdownImport = () => {
    if (!markdownText.trim()) { setMarkdownStatus('❌ 請貼上 Markdown 內容'); return; }
    try {
      const { itineraryItems, checklistItems } = parseMarkdown(markdownText);
      setItinerary(prev => [...prev, ...itineraryItems]);
      setChecklist(prev => [...prev, ...checklistItems]);
      setMarkdownStatus(`✅ 已匯入 ${itineraryItems.length} 個景點、${checklistItems.length} 個清單項目`);
      setMarkdownText('');
      setTimeout(() => { setIsMarkdownImportOpen(false); setMarkdownStatus(''); }, 1500);
    } catch { setMarkdownStatus('❌ 格式錯誤，請確認 Markdown 格式'); }
  };

  const downloadSampleMarkdown = () => {
    const sample = `# 旅程名稱（選填）\n\n## 2025-05-01\n- time: 09:00\n  title: 關西國際機場\n  location: 關西國際機場\n  transport: 關空特急 Haruka\n  transport_departure: 09:30\n  transport_duration: 75分鐘\n  transport_price: 3600\n  transport_ticket: true\n  notes: 入境後換 IC 卡\n\n## 行前清單\n- [ ] 訂機票\n- [ ] 換日幣\n- [x] 申請國際駕照\n`;
    const a=document.createElement('a');
    a.href=URL.createObjectURL(new Blob([sample],{type:'text/markdown;charset=utf-8;'}));
    a.download='行程匯入範例.md';
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
  };

  // ── Share ─────────────────────────────────────────────────────────────────────
  const addShareMember = async () => {
    const email = newShareEmail.trim().toLowerCase();
    if (!email||!email.includes('@')) { setShareStatus('請輸入正確的 Email'); return; }
    setShareStatus('🔍 查詢中...');
    try {
      const snap = await getDocs(query(collection(db,'userProfiles'),where('email','==',email)));
      if (snap.empty) { setShareStatus('❌ 找不到此 Email，對方需要先登入過 App'); return; }
      const targetProfile = snap.docs[0].data();
      const targetUid = targetProfile.uid;
      if (targetUid===uid) { setShareStatus('❌ 不能分享給自己'); return; }
      if (shareEditors.includes(targetUid)||shareViewers.includes(targetUid)) { setShareStatus('此帳號已在名單中'); return; }
      const newEditors = newShareRole==='editor' ? [...shareEditors,targetUid] : shareEditors;
      const newViewers = newShareRole==='viewer' ? [...shareViewers,targetUid] : shareViewers;
      let updatedUsers = [...users];
      if (newShareRole==='editor') {
        const memberName = targetProfile.nickname||targetProfile.displayName||email.split('@')[0];
        if (!updatedUsers.includes(memberName)) updatedUsers = [...updatedUsers,memberName];
      }
      await updateDoc(doc(db,'users',uid,'trips',tripId),{ editors:newEditors, viewers:newViewers, ownerId:uid, users:updatedUsers });
      await setDoc(doc(db,'sharedTrips',tripId),{ ownerUid:uid, tripId, editors:newEditors, viewers:newViewers });
      setShareEditors(newEditors); setShareViewers(newViewers); setUsers(updatedUsers);
      setShareEmailMap(prev=>({...prev,[targetUid]:email})); setNewShareEmail('');
      setShareStatus(`✅ 已新增 ${email}`);
    } catch { setShareStatus('❌ 儲存失敗，請再試一次'); }
  };

  const removeShareMember = async (targetUid, role) => {
    const newEditors = role==='editor' ? shareEditors.filter(e=>e!==targetUid) : shareEditors;
    const newViewers = role==='viewer' ? shareViewers.filter(e=>e!==targetUid) : shareViewers;
    try {
      await updateDoc(doc(db,'users',uid,'trips',tripId),{editors:newEditors,viewers:newViewers});
      await setDoc(doc(db,'sharedTrips',tripId),{ownerUid:uid,tripId,editors:newEditors,viewers:newViewers});
      setShareEditors(newEditors); setShareViewers(newViewers);
      setShareEmailMap(prev=>{ const u={...prev}; delete u[targetUid]; return u; });
    } catch { alert('移除失敗'); }
  };

  // ── Sorted dates for itinerary ────────────────────────────────────────────────
  const sortedDates = useMemo(() => {
    const dates = [...new Set(itinerary.map(i => i.date||'未定日期'))].sort();
    return dates;
  }, [itinerary]);

  const currentDate = sortedDates[selectedDay] || '';

  // ─────────────────────────────────────────────────────────────────────────────
  // ── RENDER ────────────────────────────────────────────────────────────────────
  // ─────────────────────────────────────────────────────────────────────────────
  return (
    <div className="relative min-h-screen max-w-md mx-auto overflow-hidden font-sans"
      style={{ background: 'linear-gradient(160deg, #f0fdf7 0%, #ecfdf5 40%, #f0f9ff 100%)' }}>
      {ConfirmUI}

      {/* ── Offline banner ── */}
      {!isOnline && (
        <div className="sticky top-0 z-50 bg-amber-400 text-white text-xs font-bold py-2 px-4 flex items-center justify-center gap-2">
          <WifiOff size={14}/> 目前離線，恢復連線後自動同步
        </div>
      )}

      {/* ═══════════════════════════════════════════════════════
          HEADER — glassmorphism sticky
      ════════════════════════════════════════════════════════ */}
      <header className="sticky top-0 z-30 bg-white/70 backdrop-blur-2xl border-b border-white/60 shadow-[0_4px_30px_rgba(0,0,0,0.05)]">
        <div className="flex items-center gap-2 px-4 pt-11 pb-2">
          <button onClick={onBack} className="p-1.5 -ml-1 text-gray-600 rounded-full active:bg-gray-100">
            <ArrowLeft size={22}/>
          </button>

          {/* Trip icon */}
          {!readOnly
            ? <button onClick={() => setTripIconIndex(i=>(i+1)%TRIP_ICONS.length)} className="w-8 h-8 rounded-xl bg-emerald-100/80 flex items-center justify-center text-emerald-700 border border-emerald-200/50 shrink-0">
                <TripIcon size={17} strokeWidth={2.5}/>
              </button>
            : <div className="w-8 h-8 rounded-xl bg-emerald-100/80 flex items-center justify-center text-emerald-700 shrink-0"><TripIcon size={17}/></div>
          }

          {/* Trip name */}
          {!readOnly && isEditingName
            ? <input ref={tripNameRef} type="text" value={tripName} maxLength={15}
                onChange={e=>setTripName(e.target.value.slice(0,15))}
                onBlur={()=>setIsEditingName(false)}
                onKeyDown={e=>e.key==='Enter'&&setIsEditingName(false)}
                className="flex-1 text-lg font-extrabold text-gray-900 bg-transparent border-b-2 border-emerald-400 outline-none"/>
            : <h1 onClick={()=>!readOnly&&setIsEditingName(true)}
                className={`flex-1 font-extrabold text-gray-900 truncate ${tripName.length>10?'text-base':'text-lg'} ${!readOnly?'cursor-text':''}`}>
                {tripName}
              </h1>
          }

          {/* Save dot */}
          <div className="group relative shrink-0">
            <div className={`w-2 h-2 rounded-full ${saveStatus==='saving'?'bg-amber-400 animate-pulse':saveStatus==='error'?'bg-red-400':'bg-emerald-400'}`}/>
            <div className="absolute right-0 top-4 hidden group-hover:block bg-gray-800 text-white text-xs rounded px-2 py-1 whitespace-nowrap z-50 shadow-lg">
              {saveStatus==='saving'?'儲存中...':saveStatus==='error'?'儲存失敗':'已同步'}
            </div>
          </div>

          {!readOnly && (
            <>
              <button onClick={()=>setIsShareOpen(true)} className="p-2 text-gray-500 hover:text-emerald-600 rounded-full active:bg-emerald-50">
                <Share2 size={20}/>
              </button>
              <button onClick={()=>setIsSettingsOpen(true)} className="p-2 text-gray-500 hover:text-emerald-600 rounded-full active:bg-emerald-50">
                <Settings size={20}/>
              </button>
            </>
          )}
          {readOnly && <span className="text-xs font-bold bg-gray-100 text-gray-500 px-2 py-1 rounded-full">👁 瀏覽</span>}
        </div>

        {/* Date range */}
        <div className="px-4 pb-3">
          {isEditingDates && !readOnly
            ? <div className="flex items-center gap-2">
                <input type="date" value={tripStartDate} onChange={e=>setTripStartDate(e.target.value)}
                  className="flex-1 text-xs border border-gray-200 rounded-lg px-2 py-1.5 bg-white/80 outline-none focus:ring-2 focus:ring-emerald-400"/>
                <span className="text-gray-400 text-xs">→</span>
                <input type="date" value={tripEndDate} min={tripStartDate} onChange={e=>setTripEndDate(e.target.value)}
                  className="flex-1 text-xs border border-gray-200 rounded-lg px-2 py-1.5 bg-white/80 outline-none focus:ring-2 focus:ring-emerald-400"/>
                <button onClick={()=>setIsEditingDates(false)} className="text-emerald-600 p-1"><Check size={16}/></button>
              </div>
            : <button onClick={()=>!readOnly&&setIsEditingDates(true)}
                className={`flex items-center gap-1.5 text-xs ${tripStartDate?'text-emerald-700 font-semibold':'text-gray-400'} active:opacity-70`}>
                <Calendar size={12}/>
                {tripStartDate&&tripEndDate ? `${fmtShort(tripStartDate)} – ${fmtShort(tripEndDate)}（${tripDateRange.length} 天）`
                  : tripStartDate ? `${fmtShort(tripStartDate)} 起`
                  : !readOnly ? '＋ 設定旅行日期' : '未設定日期'}
                {!readOnly && <Edit2 size={11} className="opacity-40 ml-1"/>}
              </button>
          }
        </div>
      </header>

      {/* ═══════════════════════════════════════════════════════
          MAIN CONTENT
      ════════════════════════════════════════════════════════ */}
      <main className="pb-28">

        {/* ══ CHECKLIST ══ */}
        {mode === 'checklist' && (
          <div>
            {/* Sub-tabs */}
            <div className="sticky top-[var(--hdr-h,112px)] z-20 bg-white/70 backdrop-blur-xl border-b border-white/50 px-4 py-3">
              <div className="flex gap-2 overflow-x-auto scrollbar-hide">
                {[['pretrip','行前清單'],['shopping','購物總覽'],['spots','收藏景點']].map(([id,label]) => (
                  <button key={id} onClick={()=>setListTab(id)}
                    className={`flex-shrink-0 px-4 py-1.5 rounded-full text-sm font-semibold transition-all ${listTab===id?'bg-emerald-600 text-white shadow-sm':'bg-white/80 text-gray-600 border border-gray-200'}`}>
                    {label}
                  </button>
                ))}
              </div>
            </div>

            {/* ── 行前清單 ── */}
            {listTab === 'pretrip' && (
              <div className="px-4 py-4 space-y-4">
                {/* Progress */}
                {checklist.length > 0 && (
                  <div className="bg-white/70 backdrop-blur-xl rounded-2xl p-4 border border-white/80 shadow-sm">
                    <div className="flex justify-between text-xs font-semibold text-gray-500 mb-2">
                      <span>準備進度</span>
                      <span>{checklist.filter(i=>i.checked).length} / {checklist.length} ({Math.round(checklist.filter(i=>i.checked).length/checklist.length*100)}%)</span>
                    </div>
                    <div className="h-2 bg-gray-100 rounded-full overflow-hidden">
                      <div className="h-full bg-emerald-500 rounded-full transition-all duration-500"
                        style={{width:`${checklist.filter(i=>i.checked).length/checklist.length*100}%`}}/>
                    </div>
                  </div>
                )}

                {/* Ticket reminders */}
                {checklist.filter(i=>i.type==='ticket').length > 0 && (
                  <div>
                    <div className="flex items-center gap-2 mb-2 px-1">
                      <Ticket size={14} className="text-orange-500"/>
                      <span className="text-xs font-bold text-gray-600 uppercase tracking-wide">購票提醒清單</span>
                      {checklist.filter(i=>i.type==='ticket'&&!i.checked).length > 0 && (
                        <span className="bg-orange-100 text-orange-700 text-xs font-bold px-2 py-0.5 rounded-full">
                          {checklist.filter(i=>i.type==='ticket'&&!i.checked).length} 待辦
                        </span>
                      )}
                    </div>
                    <div className="space-y-2">
                      {checklist.filter(i=>i.type==='ticket').filter(i=>!i.checked).map(item => {
                        const today=new Date(); today.setHours(0,0,0,0);
                        const dl=item.ticketDeadline?new Date(item.ticketDeadline):null;
                        if(dl) dl.setHours(0,0,0,0);
                        const diff=dl?Math.round((dl-today)/(1000*60*60*24)):null;
                        return (
                          <div key={item.id}
                            className={`bg-white/80 backdrop-blur-md rounded-2xl border p-4 flex items-center gap-3 shadow-sm ${diff!==null&&diff<=30?'border-orange-200 bg-orange-50/60':'border-orange-100'}`}>
                            <button onClick={()=>toggleChecklist(item.id)}
                              className="w-6 h-6 rounded-full border-2 border-orange-400 bg-white flex items-center justify-center shrink-0 active:scale-90 transition-transform">
                            </button>
                            <div className="flex-1 min-w-0">
                              <p className="text-sm font-semibold text-gray-800 truncate">{item.text}</p>
                              {item.ticketDeadline && (
                                <p className={`text-xs font-semibold mt-0.5 ${diff!==null&&diff<0?'text-red-600':diff!==null&&diff<=30?'text-orange-600':'text-gray-400'}`}>
                                  截止日：{item.ticketDeadline.slice(5).replace('-','/')}
                                  {diff!==null&&diff<=30&&diff>=0&&` （${diff} 天）`}
                                  {diff!==null&&diff<0&&' （已逾期）'}
                                </p>
                              )}
                            </div>
                            {!readOnly && <button onClick={()=>deleteChecklistItem(item.id)} className="text-gray-300 hover:text-red-400 p-1"><Trash2 size={16}/></button>}
                          </div>
                        );
                      })}

                      {checklist.filter(i=>i.type==='ticket'&&i.checked).length > 0 && (
                        <div>
                          <button onClick={()=>setShowDoneTickets(v=>!v)} className="text-xs text-gray-400 flex items-center gap-1 py-1 px-1 hover:text-gray-600">
                            <ChevronDown size={13} className={`transition-transform ${showDoneTickets?'rotate-180':''}`}/>
                            已完成購票 ({checklist.filter(i=>i.type==='ticket'&&i.checked).length})
                          </button>
                          {showDoneTickets && checklist.filter(i=>i.type==='ticket'&&i.checked).map(item => (
                            <div key={item.id} className="bg-white/60 rounded-2xl border border-gray-100 p-4 flex items-center gap-3 opacity-60 mt-2">
                              <button onClick={()=>toggleChecklist(item.id)} className="w-6 h-6 rounded-full bg-emerald-500 flex items-center justify-center shrink-0">
                                <Check size={13} className="text-white"/>
                              </button>
                              <span className="text-sm text-gray-500 line-through flex-1">{item.text}</span>
                              {!readOnly && <button onClick={()=>deleteChecklistItem(item.id)} className="text-gray-300 hover:text-red-400 p-1"><Trash2 size={15}/></button>}
                            </div>
                          ))}
                        </div>
                      )}
                    </div>

                    <div className="my-4 h-px bg-gray-200"/>
                  </div>
                )}

                {/* General prep */}
                <div>
                  <div className="flex items-center gap-2 mb-2 px-1">
                    <CheckSquare size={14} className="text-gray-500"/>
                    <span className="text-xs font-bold text-gray-600 uppercase tracking-wide">行前準備</span>
                  </div>
                  <div className="bg-white/70 backdrop-blur-xl rounded-2xl border border-white/80 shadow-sm overflow-hidden">
                    {checklist.filter(i=>i.type!=='ticket'&&!i.checked).map((item, idx, arr) => (
                      <div key={item.id} className={`flex items-center gap-3 px-4 py-3.5 ${idx<arr.length-1?'border-b border-gray-100/80':''}`}>
                        <button onClick={()=>toggleChecklist(item.id)}
                          className="w-5 h-5 rounded-[5px] border-2 border-gray-300 flex items-center justify-center shrink-0 active:scale-90 transition-transform bg-white">
                        </button>
                        <span className="flex-1 text-sm text-gray-800">{item.text}</span>
                        {!readOnly && <button onClick={()=>deleteChecklistItem(item.id)} className="text-gray-200 hover:text-red-400 p-1"><Trash2 size={15}/></button>}
                      </div>
                    ))}
                    {checklist.filter(i=>i.type!=='ticket'&&i.checked).length > 0 && (
                      <>
                        <button onClick={()=>setShowDoneRegular(v=>!v)} className="flex items-center gap-1 text-xs text-gray-400 px-4 py-2.5 w-full hover:text-gray-600 border-t border-gray-100">
                          <ChevronDown size={13} className={`transition-transform ${showDoneRegular?'rotate-180':''}`}/>
                          已完成 ({checklist.filter(i=>i.type!=='ticket'&&i.checked).length})
                        </button>
                        {showDoneRegular && checklist.filter(i=>i.type!=='ticket'&&i.checked).map((item,idx,arr) => (
                          <div key={item.id} className={`flex items-center gap-3 px-4 py-3.5 opacity-50 ${idx<arr.length-1?'border-b border-gray-100':''}`}>
                            <button onClick={()=>toggleChecklist(item.id)}
                              className="w-5 h-5 rounded-[5px] bg-emerald-500 flex items-center justify-center shrink-0">
                              <Check size={11} className="text-white"/>
                            </button>
                            <span className="flex-1 text-sm text-gray-500 line-through">{item.text}</span>
                            {!readOnly && <button onClick={()=>deleteChecklistItem(item.id)} className="text-gray-200 hover:text-red-400 p-1"><Trash2 size={15}/></button>}
                          </div>
                        ))}
                      </>
                    )}
                    {checklist.filter(i=>i.type!=='ticket').length === 0 && (
                      <div className="px-4 py-8 text-center text-gray-400 text-sm">尚無清單項目</div>
                    )}
                  </div>
                </div>

                {/* Add input */}
                {!readOnly && (
                  <div className="flex gap-2">
                    <input type="text" value={newChecklistItem} onChange={e=>setNewChecklistItem(e.target.value)}
                      onKeyDown={e=>e.key==='Enter'&&addChecklistItem()}
                      placeholder="新增清單項目…"
                      className="flex-1 bg-white/80 backdrop-blur-md border border-gray-200 rounded-2xl px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-emerald-400 shadow-sm"/>
                    <button onClick={addChecklistItem} className="px-5 bg-emerald-600 text-white rounded-2xl shadow-sm font-semibold active:scale-95 transition-transform">
                      <Plus size={20}/>
                    </button>
                  </div>
                )}

                {checklist.length === 0 && (
                  <div className="text-center py-12 text-gray-400 flex flex-col items-center gap-2">
                    <ListTodo size={44} className="opacity-20"/>
                    <p className="text-sm">目前沒有清單項目</p>
                  </div>
                )}
              </div>
            )}

            {/* ── 購物總覽 ── */}
            {listTab === 'shopping' && (
              <div className="px-4 py-4 space-y-4">
                {!readOnly && (
                  <div className="bg-white/70 backdrop-blur-xl rounded-2xl border border-white/80 p-4 space-y-3 shadow-sm">
                    <p className="text-sm font-semibold text-gray-700">新增購物項目</p>
                    <div className="flex gap-2">
                      <select className="w-1/3 border border-gray-200 rounded-xl p-2 text-sm bg-white outline-none" value={globalShopDate} onChange={e=>{setGlobalShopDate(e.target.value);setGlobalShopId('');}}>
                        <option value="">選擇日期</option>
                        {[...new Set(itinerary.map(i=>i.date))].filter(Boolean).sort().map(d=><option key={d} value={d}>{fmtDate(d)}</option>)}
                      </select>
                      <select className="flex-1 border border-gray-200 rounded-xl p-2 text-sm bg-white outline-none disabled:bg-gray-50 disabled:text-gray-300" value={globalShopId} onChange={e=>setGlobalShopId(e.target.value)} disabled={!globalShopDate}>
                        <option value="">選擇景點</option>
                        {itinerary.filter(i=>i.date===globalShopDate).map(i=><option key={i.id} value={i.id}>{i.time} - {i.title}</option>)}
                      </select>
                    </div>
                    <div className="flex gap-2">
                      <input type="text" placeholder="輸入購買項目…" className="flex-1 border border-gray-200 rounded-xl px-3 py-2 text-sm outline-none bg-white" value={globalNewShop} onChange={e=>setGlobalNewShop(e.target.value)} onKeyDown={e=>e.key==='Enter'&&addGlobalShop()}/>
                      <button onClick={addGlobalShop} disabled={!globalShopId||!globalNewShop.trim()} className="px-4 bg-emerald-600 text-white rounded-xl disabled:opacity-40"><Plus size={18}/></button>
                    </div>
                  </div>
                )}
                {(() => {
                  const shopItems = itinerary.filter(i=>i.shoppingList?.length>0);
                  let checked=0, total=0;
                  shopItems.forEach(i=>{ total+=i.shoppingList.length; checked+=i.shoppingList.filter(s=>s.checked).length; });
                  if (total===0) return <div className="text-center py-12 text-gray-400 flex flex-col items-center gap-2"><ShoppingBag size={44} className="opacity-20"/><p className="text-sm">目前沒有任何購物清單</p></div>;
                  return (
                    <>
                      <div className="bg-white/70 backdrop-blur-xl rounded-2xl border border-white/80 p-4 shadow-sm">
                        <div className="flex justify-between text-xs font-semibold text-gray-500 mb-2"><span>購買進度</span><span>{checked}/{total} ({Math.round(checked/total*100)}%)</span></div>
                        <div className="h-2 bg-gray-100 rounded-full overflow-hidden"><div className="h-full bg-emerald-500 transition-all" style={{width:`${checked/total*100}%`}}/></div>
                      </div>
                      {shopItems.map(item => (
                        <div key={item.id} className="bg-white/70 backdrop-blur-xl rounded-2xl border border-white/80 p-4 shadow-sm">
                          <div className="flex items-center gap-1.5 text-sm text-emerald-700 font-semibold mb-3 pb-2 border-b border-gray-100">
                            <MapPin size={14}/>{item.title}<span className="text-xs text-gray-400 ml-1">({fmtDate(item.date)})</span>
                          </div>
                          <div className="space-y-2.5">
                            {item.shoppingList.map(s => (
                              <div key={s.id} className="flex items-center gap-3 group">
                                <button onClick={()=>toggleShop(item.id,s.id)} className={`w-5 h-5 rounded-full border-2 flex items-center justify-center shrink-0 transition-all ${s.checked?'bg-emerald-500 border-emerald-500':'border-gray-300'}`}>
                                  {s.checked && <Check size={11} className="text-white"/>}
                                </button>
                                <span className={`flex-1 text-sm ${s.checked?'line-through text-gray-400':'text-gray-700'}`}>{s.text}</span>
                                {!readOnly && <button onClick={()=>delGlobalShop(item.id,s.id)} className="text-gray-200 hover:text-red-400 opacity-0 group-hover:opacity-100 p-1"><Trash2 size={14}/></button>}
                              </div>
                            ))}
                          </div>
                        </div>
                      ))}
                    </>
                  );
                })()}
              </div>
            )}

            {/* ── 收藏景點 ── */}
            {listTab === 'spots' && (
              <div className="px-4 py-4 space-y-3">
                {!readOnly && (
                  <div className="bg-white/70 backdrop-blur-xl rounded-2xl border border-white/80 p-4 space-y-3 shadow-sm">
                    <input type="text" placeholder="景點名稱…" className="w-full border border-gray-200 rounded-xl px-3 py-2.5 text-sm bg-white outline-none focus:ring-2 focus:ring-emerald-400" value={savedSpotName} onChange={e=>setSavedSpotName(e.target.value)}/>
                    <textarea placeholder="備註（來源、特色…）" className="w-full border border-gray-200 rounded-xl px-3 py-2.5 text-sm bg-white outline-none resize-none h-16 focus:ring-2 focus:ring-emerald-400" value={savedSpotNote} onChange={e=>setSavedSpotNote(e.target.value)}/>
                    <input type="url" placeholder="來源連結 https://…" className="w-full border border-gray-200 rounded-xl px-3 py-2.5 text-sm bg-white outline-none focus:ring-2 focus:ring-emerald-400" value={savedSpotUrl} onChange={e=>setSavedSpotUrl(e.target.value)}/>
                    <button onClick={()=>{ if(!savedSpotName.trim())return; setSavedSpots(p=>[...p,{id:crypto.randomUUID(),name:savedSpotName.trim(),note:savedSpotNote.trim(),url:savedSpotUrl.trim(),createdAt:new Date().toISOString()}]); setSavedSpotName(''); setSavedSpotNote(''); setSavedSpotUrl(''); }}
                      className="w-full py-2.5 bg-emerald-600 text-white font-semibold rounded-xl text-sm flex items-center justify-center gap-2 active:scale-95 transition-transform">
                      <Plus size={15}/>加入收藏
                    </button>
                  </div>
                )}
                {savedSpots.length === 0 && <div className="text-center py-12 text-gray-400 flex flex-col items-center gap-2"><Star size={40} className="opacity-20"/><p className="text-sm">還沒有收藏景點</p></div>}
                {savedSpots.map(spot => (
                  <div key={spot.id} className="bg-white/70 backdrop-blur-xl rounded-2xl border border-white/80 shadow-sm overflow-hidden">
                    <div className="flex items-center gap-2 p-4">
                      <button onClick={()=>setExpandedSpotId(expandedSpotId===spot.id?null:spot.id)} className="flex-1 flex items-center gap-2 text-left">
                        <Star size={14} className="text-amber-400 shrink-0 fill-amber-400"/>
                        <span className="font-semibold text-sm text-gray-800">{spot.name}</span>
                        {(spot.note||spot.url) && <ChevronDown size={14} className={`text-gray-400 transition-transform ${expandedSpotId===spot.id?'rotate-180':''}`}/>}
                      </button>
                      {!readOnly && <>
                        <button onClick={()=>setAddingSpotToDate(spot.id)} className="text-xs text-emerald-700 bg-emerald-50 border border-emerald-200 px-2.5 py-1.5 rounded-full font-semibold active:scale-95">＋加入行程</button>
                        <button onClick={()=>setSavedSpots(p=>p.filter(s=>s.id!==spot.id))} className="p-1.5 text-gray-300 hover:text-red-400"><Trash2 size={14}/></button>
                      </>}
                    </div>
                    {expandedSpotId===spot.id && (spot.note||spot.url) && (
                      <div className="px-4 pb-3 pt-0 space-y-1 border-t border-gray-100">
                        {spot.note && <p className="text-xs text-gray-600 pt-2">{spot.note}</p>}
                        {spot.url  && <a href={spot.url} target="_blank" rel="noreferrer" className="text-xs text-emerald-600 underline truncate block">{spot.url}</a>}
                      </div>
                    )}
                    {addingSpotToDate===spot.id && (
                      <div className="px-4 pb-3 pt-2 border-t border-emerald-100 bg-emerald-50/50 space-y-2">
                        <p className="text-xs font-semibold text-emerald-700">選擇要加入的日期：</p>
                        <select className="w-full border border-emerald-200 rounded-xl p-2 text-sm bg-white outline-none" defaultValue="" onChange={e=>{
                          if(!e.target.value)return;
                          setItinerary(p=>[...p,{id:crypto.randomUUID(),type:'place',date:e.target.value,time:'',title:spot.name,location:'',notes:spot.note||'',website:spot.url||'',transport:'',transportSegments:[],shoppingList:[],tickets:'',lastEditedBy:currentUserName||'',lastEditedAt:new Date().toISOString()}]);
                          setSavedSpots(p=>p.filter(s=>s.id!==spot.id)); setAddingSpotToDate(null); showToast('✅ 已加入行程');
                        }}>
                          <option value="">選擇日期…</option>
                          {(tripDateRange.length>0?tripDateRange:[...new Set(itinerary.map(i=>i.date))].filter(Boolean).sort()).map((d,i)=>{const dt=new Date(d);return<option key={d} value={d}>第{i+1}天 {dt.getMonth()+1}/{dt.getDate()}</option>;})}
                          <option value="undated">不指定日期</option>
                        </select>
                        <button onClick={()=>setAddingSpotToDate(null)} className="text-xs text-gray-400 w-full text-center py-1">取消</button>
                      </div>
                    )}
                  </div>
                ))}
              </div>
            )}
          </div>
        )}

        {/* ══ ITINERARY ══ */}
        {mode === 'itinerary' && (
          <div>
            {/* Day tabs */}
            <div className="bg-white/70 backdrop-blur-xl border-b border-white/50 sticky top-[var(--hdr-h,112px)] z-20">
              <div className="flex overflow-x-auto gap-2 px-4 py-3 scrollbar-hide">
                {sortedDates.map((date, idx) => (
                  <button key={date} onClick={()=>setSelectedDay(idx)}
                    className={`flex-shrink-0 px-4 py-1.5 rounded-full text-sm font-semibold transition-all ${selectedDay===idx?'bg-gray-900/80 text-white shadow-md backdrop-blur-sm':'bg-white/80 text-gray-600 border border-gray-200'}`}>
                    {tripDayLabel(date).replace('　',' ')}
                  </button>
                ))}
                {!readOnly && (
                  <button onClick={()=>{ setIsEditMode(m=>!m); }}
                    className={`flex-shrink-0 px-3 py-1.5 rounded-full text-xs font-semibold transition-all border ml-auto ${isEditMode?'bg-emerald-100 text-emerald-700 border-emerald-200':'bg-white/80 text-gray-500 border-gray-200'}`}>
                    {isEditMode?'完成編輯':'編輯'}
                  </button>
                )}
              </div>
            </div>

            {/* Flex todos */}
            {(!readOnly || flexTodos.length > 0) && (
              <div className="mx-4 mt-4 bg-amber-50/80 backdrop-blur-md border border-amber-200/60 rounded-2xl overflow-hidden shadow-sm">
                <button onClick={()=>setFlexCollapsed(v=>!v)} className="w-full flex items-center justify-between px-4 py-3">
                  <div className="flex items-center gap-2 text-sm font-semibold text-amber-800">
                    <Zap size={15} className="text-amber-500"/>
                    彈性待辦
                    <span className="text-xs bg-amber-200 text-amber-700 px-1.5 py-0.5 rounded-full">{flexTodos.filter(t=>!t.checked).length} 項</span>
                  </div>
                  {flexCollapsed?<ChevronDown size={15} className="text-amber-400"/>:<ChevronUp size={15} className="text-amber-400"/>}
                </button>
                {!flexCollapsed && (
                  <div className="px-4 pb-4 space-y-2">
                    {flexTodos.map(todo => (
                      <div key={todo.id} className={`bg-white border rounded-xl p-3 flex gap-3 items-start ${todo.checked?'opacity-60 border-gray-100':'border-amber-100'}`}>
                        <button onClick={()=>setFlexTodos(p=>p.map(t=>t.id===todo.id?{...t,checked:!t.checked}:t))}
                          className={`mt-0.5 w-5 h-5 rounded-full border-2 flex items-center justify-center shrink-0 ${todo.checked?'bg-amber-400 border-amber-400':'border-amber-300'}`}>
                          {todo.checked&&<Check size={10} className="text-white"/>}
                        </button>
                        <div className="flex-1 min-w-0">
                          <div className={`font-semibold text-sm ${todo.checked?'line-through text-gray-400':'text-gray-800'}`}>{todo.title}</div>
                          {todo.notes && <div className="text-xs text-gray-500 mt-0.5">{todo.notes}</div>}
                        </div>
                        {!readOnly && (
                          <div className="flex gap-1 shrink-0">
                            <select className="text-xs border border-emerald-200 rounded-lg px-1.5 py-1 bg-emerald-50 text-emerald-700 outline-none max-w-[90px]" defaultValue=""
                              onChange={e=>{if(!e.target.value)return; setItinerary(prev=>[...prev,{id:crypto.randomUUID(),title:todo.title,notes:todo.notes||'',date:e.target.value,time:'',location:'',transport:'',transportSegments:[],shoppingList:[],tickets:'',lastEditedBy:currentUserName||''}]); setFlexTodos(p=>p.filter(t=>t.id!==todo.id)); }}>
                              <option value="">移入行程…</option>
                              {tripDateRange.length>0 ? tripDateRange.map((d,i)=>{const dt=new Date(d);return<option key={d} value={d}>第{i+1}天 {dt.getMonth()+1}/{dt.getDate()}</option>;}) : sortedDates.map(d=><option key={d} value={d}>{fmtDate(d)}</option>)}
                            </select>
                            <button onClick={()=>setFlexTodos(p=>p.filter(t=>t.id!==todo.id))} className="p-1 text-gray-400 hover:text-red-400"><X size={13}/></button>
                          </div>
                        )}
                      </div>
                    ))}
                    {flexTodos.length===0 && <div className="text-xs text-amber-600 py-1 text-center">目前沒有彈性待辦</div>}
                    {!readOnly && (
                      <div className="flex gap-2 mt-1">
                        <input type="text" placeholder="新增彈性待辦（如：超市採購）" maxLength={30}
                          className="flex-1 border border-amber-200 rounded-xl px-3 py-2 text-sm bg-white outline-none focus:ring-2 focus:ring-amber-300"
                          onKeyDown={e=>{ if(e.key==='Enter'&&e.target.value.trim()) { setFlexTodos(p=>[...p,{id:crypto.randomUUID(),title:e.target.value.trim(),notes:'',checked:false}]); e.target.value=''; } }}/>
                        <span className="text-xs text-amber-500 self-center shrink-0">Enter</span>
                      </div>
                    )}
                  </div>
                )}
              </div>
            )}

            {/* Timeline */}
            <div className="px-4 py-4 relative">
              {/* Sort button */}
              {isEditMode && !readOnly && (
                <div className="flex justify-between items-center mb-3">
                  <span className="text-xs text-gray-500">拖曳順序模式</span>
                  <button onClick={sortByTime} className="text-xs text-emerald-700 font-semibold px-3 py-1.5 bg-emerald-50 rounded-full border border-emerald-200">依時間排序</button>
                </div>
              )}

              {itinerary.filter(i=>i.date===currentDate).length === 0 && (
                <div className="text-center py-16 text-gray-400 flex flex-col items-center gap-3">
                  <MapPin size={44} className="opacity-20"/>
                  <p className="font-medium text-sm">這天還沒有行程</p>
                  {!readOnly && !isEditMode && <button onClick={()=>setIsEditMode(true)} className="mt-1 px-4 py-2 bg-emerald-600 text-white text-sm font-semibold rounded-2xl active:scale-95">開始編輯行程</button>}
                </div>
              )}

              {isEditMode
                ? /* Edit mode list */
                  <div className="space-y-2">
                    {itinerary.filter(i=>i.date===currentDate).map((item, dayIdx) => {
                      const isMoving = movingId===item.id, isTarget = movingId&&movingId!==item.id;
                      return (
                        <div key={item.id} onClick={()=>isTarget&&handleTapMove(item.id)}
                          className={`bg-white/80 backdrop-blur-md rounded-2xl border p-3 flex gap-3 items-center shadow-sm transition-all
                            ${isMoving?'border-emerald-400 ring-2 ring-emerald-200':''} ${isTarget?'border-dashed border-emerald-300 cursor-pointer':'border-white/80'}`}>
                          <button onClick={e=>{e.stopPropagation();setMovingId(isMoving?null:item.id);}}
                            className={`w-8 h-8 flex flex-col items-center justify-center gap-1 rounded-lg shrink-0 ${isMoving?'bg-emerald-500':'text-gray-300 bg-gray-50'}`}>
                            {[0,1,2].map(i=><div key={i} className={`w-3.5 h-0.5 rounded ${isMoving?'bg-white':'bg-gray-300'}`}/>)}
                          </button>
                          <div className="flex-1 min-w-0" onClick={e=>{if(!isTarget){e.stopPropagation(); setEditingItem(item.type==='transport'?{...item}:{...item,transportSegments:normalizeTransportSegments(item)}); setIsOptionalOpen(false); setIsEditModalOpen(true);}}}>
                            <div className="flex items-center gap-2">
                              <span className="text-xs font-bold text-emerald-600">{item.time}</span>
                              {item.type==='transport'?<Car size={12} className="text-gray-400"/>:<MapPin size={12} className="text-gray-400"/>}
                              <span className="font-semibold text-sm text-gray-800 truncate">
                                {item.type==='transport' ? (item.transportSegments?.map(s=>s.mode).filter(Boolean).join(' → ')||item.title||'交通') : item.title}
                              </span>
                            </div>
                            <p className="text-xs text-gray-400 truncate mt-0.5">{item.location||item.notes||''}</p>
                          </div>
                          {!movingId && (
                            <div className="flex gap-1.5 shrink-0">
                              <button onClick={e=>{e.stopPropagation(); setEditingItem(item.type==='transport'?{...item}:{...item,transportSegments:normalizeTransportSegments(item)}); setIsOptionalOpen(false); setIsEditModalOpen(true);}} className="p-2 text-blue-600 bg-blue-50 rounded-xl"><Edit2 size={15}/></button>
                              <button onClick={e=>{e.stopPropagation(); deleteItineraryItem(item.id);}} className="p-2 text-red-500 bg-red-50 rounded-xl"><Trash2 size={15}/></button>
                            </div>
                          )}
                        </div>
                      );
                    })}
                    {/* Date-level add buttons */}
                    <div className="flex gap-2 pt-1">
                      <button onClick={()=>{setEditingItem({type:'place',date:currentDate,title:'',time:'12:00',location:'',transport:'',notes:'',website:'',hours:'',shoppingList:[],tickets:'',transportSegments:[]}); setIsOptionalOpen(false); setIsEditModalOpen(true);}}
                        className="flex-1 flex items-center justify-center gap-1.5 py-3 border-2 border-dashed border-emerald-300 text-emerald-700 font-semibold rounded-2xl text-sm hover:bg-emerald-50">
                        <Plus size={15}/>新增景點
                      </button>
                      <button onClick={()=>{setEditingItem({type:'transport',date:currentDate,time:'',title:'',transportSegments:[emptySegment()],notes:''}); setIsOptionalOpen(false); setIsEditModalOpen(true);}}
                        className="flex-1 flex items-center justify-center gap-1.5 py-3 border-2 border-dashed border-gray-300 text-gray-600 font-semibold rounded-2xl text-sm hover:bg-gray-50">
                        <Car size={15}/>新增交通
                      </button>
                    </div>
                  </div>
                : /* View mode timeline */
                  <div className="relative pl-4">
                    <div className="absolute left-[23px] top-5 bottom-5 w-0.5 bg-emerald-200/60"/>
                    {itinerary.filter(i=>i.date===currentDate).map((item, idx) => (
                      <div key={item.id} className="flex gap-4 mb-6">
                        {/* Time + dot */}
                        <div className="flex flex-col items-center shrink-0 w-10">
                          <span className="text-xs font-bold text-gray-500 leading-none mt-1">{item.time}</span>
                          <div className={`mt-2 w-3.5 h-3.5 rounded-full border-2 border-white shadow-sm z-10 ${item.type==='transport'?'bg-orange-400':'bg-emerald-500'}`}/>
                        </div>
                        {/* Card */}
                        <div className="flex-1 bg-white/80 backdrop-blur-xl rounded-2xl border border-white/80 shadow-[0_4px_20px_rgba(0,0,0,0.06)] overflow-hidden mb-1">
                          <div className="p-4">
                            <div className="flex items-start justify-between mb-1.5">
                              <h3 className="text-[15px] font-bold text-gray-900 leading-snug pr-2">
                                {item.type==='transport' ? (item.transportSegments?.map(s=>s.mode).filter(Boolean).join(' → ')||item.title||'交通') : item.title}
                              </h3>
                              <button onClick={()=>setExpandedItems(prev=>{const s=new Set(prev);s.has(item.id)?s.delete(item.id):s.add(item.id);return s;})} className="text-gray-400 p-0.5 shrink-0">
                                {expandedItems.has(item.id)?<ChevronUp size={16}/>:<ChevronDown size={16}/>}
                              </button>
                            </div>
                            {item.location && (
                              <a href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(item.location)}`} target="_blank" rel="noreferrer"
                                className="flex items-center gap-1 text-xs text-blue-500 hover:underline mb-2">
                                <MapPin size={11}/>{item.location}
                              </a>
                            )}
                            {item.type!=='transport' && item.notes && (
                              <p className="text-sm text-gray-600 leading-relaxed">{item.notes}</p>
                            )}
                            {item.type==='transport' && item.notes && (
                              <p className="text-xs text-gray-500">{item.notes}</p>
                            )}
                            {expandedItems.has(item.id) && (
                              <div className="mt-3 pt-3 border-t border-gray-100 space-y-2">
                                {item.hours && <p className="text-xs text-gray-500 flex items-center gap-1.5"><Clock size={12}/>營業時間：{item.hours}</p>}
                                {item.tickets && <p className="text-xs text-gray-500 flex items-center gap-1.5"><Ticket size={12}/>門票：{item.tickets}</p>}
                                {item.website && <a href={item.website} target="_blank" rel="noreferrer" className="text-xs text-blue-500 flex items-center gap-1.5 hover:underline"><Globe size={12}/>官方網站</a>}
                                {item.shoppingList?.length > 0 && (
                                  <div className="bg-pink-50/60 rounded-xl p-2.5">
                                    <p className="text-xs font-semibold text-pink-700 mb-1.5 flex items-center gap-1"><ShoppingBag size={12}/>預計購買</p>
                                    {item.shoppingList.map(s=>(
                                      <div key={s.id} className={`flex items-center gap-2 text-xs mb-1 ${s.checked?'opacity-50 line-through text-gray-400':'text-gray-700'}`}>
                                        <div className={`w-3.5 h-3.5 rounded-full border shrink-0 flex items-center justify-center ${s.checked?'bg-pink-400 border-pink-400':'border-pink-300'}`}>
                                          {s.checked&&<Check size={9} className="text-white"/>}
                                        </div>
                                        {s.text}
                                      </div>
                                    ))}
                                  </div>
                                )}
                              </div>
                            )}
                          </div>
                          {/* Action bar */}
                          <div className="flex border-t border-gray-100">
                            {!readOnly && (
                              <button onClick={()=>setAddingExpenseFor(item)} className="flex-1 flex items-center justify-center gap-1.5 py-2.5 text-xs font-semibold text-gray-600 bg-gray-50/80 hover:bg-gray-100 transition-colors">
                                <DollarSign size={14}/>記一筆
                              </button>
                            )}
                            {item.location && (
                              <a href={`https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(item.location)}`} target="_blank" rel="noreferrer"
                                className="flex-1 flex items-center justify-center gap-1.5 py-2.5 text-xs font-semibold text-emerald-700 bg-emerald-50/80 hover:bg-emerald-100 transition-colors">
                                <Navigation size={14}/>導航
                              </a>
                            )}
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>
              }
            </div>
          </div>
        )}

        {/* ══ FINANCE ══ */}
        {mode === 'finance' && (
          <div className="px-4 py-4 space-y-4">
            {/* Summary card */}
            <div className="bg-emerald-600 rounded-3xl p-5 shadow-lg">
              <p className="text-emerald-200 text-xs font-semibold mb-1">總花費 ({baseCurrency})</p>
              <p className="text-4xl font-extrabold text-white mb-4 tracking-tight">{Math.round(financeSummary.total).toLocaleString()}</p>
              {/* Per-person grid */}
              <div className="grid grid-cols-2 gap-2.5">
                {users.map(u => {
                  const s = financeSummary.userStats[u];
                  if (!s) return null;
                  return (
                    <div key={u} className="bg-white/20 rounded-2xl p-3 backdrop-blur-sm">
                      <p className="text-emerald-100 text-xs font-medium mb-1 truncate">{u}</p>
                      <p className="text-white text-xl font-extrabold">{Math.round(s.consumed).toLocaleString()}</p>
                      <p className="text-emerald-200/80 text-xs mt-1">已付 {Math.round(s.paid).toLocaleString()}</p>
                      {(() => {
                        const bal = s.paid - s.consumed;
                        return <p className={`text-xs font-bold mt-0.5 ${bal>0?'text-green-300':bal<0?'text-red-300':'text-emerald-100'}`}>
                          {bal>0?`需收款 ${Math.abs(Math.round(bal)).toLocaleString()}`:bal<0?`需付款 ${Math.abs(Math.round(bal)).toLocaleString()}`:'已結清'}
                        </p>;
                      })()}
                    </div>
                  );
                })}
              </div>
            </div>

            {/* Settlement */}
            {settlement.length > 0 && (
              <div className="bg-white/70 backdrop-blur-xl rounded-2xl border border-white/80 p-4 shadow-sm">
                <p className="text-xs font-bold text-gray-500 uppercase tracking-wide mb-3">建議結算清單</p>
                <div className="space-y-2.5">
                  {settlement.map((t, i) => (
                    <div key={i} className="flex items-center gap-3 bg-gray-50 rounded-xl px-4 py-3">
                      <span className="font-bold text-red-500 text-sm">{t.from}</span>
                      <ArrowRight size={14} className="text-gray-400 shrink-0"/>
                      <span className="font-bold text-emerald-600 text-sm">{t.to}</span>
                      <span className="ml-auto font-bold text-gray-800 text-sm">{baseCurrency} {t.amount.toLocaleString()}</span>
                    </div>
                  ))}
                </div>
                <p className="text-xs text-gray-400 mt-3">依分攤設定自動計算，最少交易筆數完成結清。</p>
              </div>
            )}
            {settlement.length===0 && expenses.length>0 && (
              <div className="text-center py-4 bg-emerald-50 rounded-2xl border border-emerald-100">
                <p className="text-emerald-600 font-semibold text-sm">🎉 所有人已結清，無需轉帳！</p>
              </div>
            )}

            {/* Action row */}
            <div className="flex gap-3">
              {!readOnly && (
                <button onClick={()=>setAddingExpenseFor({title:'一般花費'})} className="flex-1 py-3 bg-white/80 backdrop-blur-xl border border-white/80 text-gray-800 font-semibold rounded-2xl flex items-center justify-center gap-2 shadow-sm active:scale-95 transition-transform">
                  <Plus size={17}/>記一筆
                </button>
              )}
              <button onClick={exportCSV} className="flex-1 py-3 bg-white/80 backdrop-blur-xl border border-white/80 text-gray-800 font-semibold rounded-2xl flex items-center justify-center gap-2 shadow-sm active:scale-95 transition-transform">
                <Download size={17}/>匯出 CSV
              </button>
            </div>

            {/* Expense list */}
            <div>
              <p className="text-xs font-bold text-gray-500 uppercase tracking-wide mb-3 px-1">帳務明細</p>
              {expenses.length === 0 && <div className="text-center text-gray-400 py-8 text-sm">尚無記帳紀錄</div>}
              <div className="space-y-2.5">
                {expenses.map(exp => {
                  const rel = itinerary.find(i=>i.id===exp.itineraryId);
                  return (
                    <div key={exp.id} onClick={()=>!readOnly&&setEditingExpense(exp)}
                      className={`bg-white/80 backdrop-blur-xl rounded-2xl border border-white/80 p-4 shadow-sm flex items-start gap-3 ${!readOnly?'cursor-pointer active:scale-[0.99] transition-transform':''}`}>
                      <div className="flex-1 min-w-0">
                        <p className="font-semibold text-gray-900 text-sm truncate">{exp.description}</p>
                        <div className="flex flex-wrap gap-2 mt-1.5 items-center">
                          <span className="text-xs bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded-lg font-medium border border-emerald-100">{exp.category||'其他'}</span>
                          <span className="text-xs text-gray-400">付：{exp.paidBy}</span>
                          <span className="text-xs text-gray-400">分：{exp.splitMode==='aa'?`AA×${(exp.aaSplitAmong||exp.splitAmong||[]).length}`:(exp.splitAmong||[]).join(',')}</span>
                          {rel && <span className="text-xs text-emerald-600 truncate">📍{rel.title}</span>}
                        </div>
                      </div>
                      <div className="shrink-0 text-right">
                        <p className="font-bold text-gray-900 text-sm">{exp.amount} {exp.currency}</p>
                        {exp.currency!==baseCurrency && (() => {
                          const c = Math.round((exp.amount*(rates[exp.currency]||1))/(rates[baseCurrency]||1));
                          return <p className="text-xs text-gray-400">≈ {c.toLocaleString()} {baseCurrency}</p>;
                        })()}
                        {!readOnly && <button onClick={e=>{e.stopPropagation();deleteExpense(exp.id);}} className="text-xs text-gray-300 hover:text-red-400 mt-1">刪除</button>}
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          </div>
        )}
      </main>

      {/* ═══════════════════════════════════════════════════════
          BOTTOM NAVIGATION
      ════════════════════════════════════════════════════════ */}
      <nav className="fixed bottom-0 left-1/2 -translate-x-1/2 w-full max-w-md bg-white/80 backdrop-blur-2xl border-t border-white/60 pb-safe pt-2 px-8 flex items-end justify-around z-40 shadow-[0_-8px_30px_rgba(0,0,0,0.05)]">
        {/* 行前清單 */}
        <button onClick={()=>setMode('checklist')} className={`flex flex-col items-center gap-1 py-2 transition-all ${mode==='checklist'?'text-emerald-600':'text-gray-400'}`}>
          <CheckSquare size={22} strokeWidth={mode==='checklist'?2.5:2}/>
          <span className="text-[10px] font-semibold">行前清單</span>
        </button>

        {/* 行程計畫 — center raised */}
        <div className="flex flex-col items-center -mb-2">
          <button onClick={()=>setMode('itinerary')}
            className={`w-14 h-14 rounded-[18px] flex flex-col items-center justify-center gap-1 shadow-lg transition-all ${mode==='itinerary'?'bg-gray-900 text-white scale-105':'bg-gray-800/80 text-white/80'}`}>
            <Map size={22} strokeWidth={2}/>
            <span className="text-[9px] font-bold">行程計畫</span>
          </button>
        </div>

        {/* 記帳分帳 */}
        <button onClick={()=>setMode('finance')} className={`flex flex-col items-center gap-1 py-2 transition-all ${mode==='finance'?'text-emerald-600':'text-gray-400'}`}>
          <Wallet size={22} strokeWidth={mode==='finance'?2.5:2}/>
          <span className="text-[10px] font-semibold">記帳分帳</span>
        </button>
      </nav>

      {/* ── Toast ── */}
      {toast && (
        <div className="fixed bottom-24 left-1/2 -translate-x-1/2 z-50 bg-gray-900/90 backdrop-blur-md text-white text-sm font-medium px-5 py-2.5 rounded-full shadow-xl pointer-events-none">
          {toast}
        </div>
      )}

      {/* ── Scroll top ── */}
      {showScrollTop && (
        <button onClick={()=>window.scrollTo({top:0,behavior:'smooth'})}
          className="fixed bottom-24 right-5 z-40 bg-white/80 backdrop-blur-xl border border-gray-200 text-gray-700 p-3 rounded-full shadow-lg active:scale-95 transition-transform">
          <ChevronUp size={20}/>
        </button>
      )}

      {/* ═══════════════════════════════════════════════════════
          MODALS
      ════════════════════════════════════════════════════════ */}

      {/* ── Edit itinerary item modal ── */}
      {isEditModalOpen && editingItem && (
        <div className="fixed inset-0 z-50 flex flex-col justify-end bg-black/30 backdrop-blur-sm max-w-md mx-auto left-1/2 -translate-x-1/2 w-full">
          <div onClick={()=>{setIsEditModalOpen(false);setIsOptionalOpen(false);}} className="flex-1"/>
          <div className="bg-white/95 backdrop-blur-2xl w-full rounded-t-[28px] max-h-[88%] flex flex-col shadow-[0_-12px_40px_rgba(0,0,0,0.12)] border-t border-white/60">
            {/* Modal header — X | title | 儲存 always visible */}
            <div className="flex items-center justify-between px-5 py-4 border-b border-gray-100 bg-white/95 rounded-t-[28px]">
              <button onClick={()=>{setIsEditModalOpen(false);setIsOptionalOpen(false);}} className="p-2 -ml-2 text-gray-400 hover:text-gray-700 bg-gray-100 rounded-full">
                <X size={20}/>
              </button>
              <div className="flex items-center gap-2">
                <span className="text-base font-extrabold text-gray-900">{editingItem.id?'編輯行程':'新增行程'}</span>
                {!editingItem.id && (
                  <div className="flex bg-gray-100 p-0.5 rounded-xl">
                    <button onClick={()=>setEditingItem({...editingItem,type:'place'})} className={`px-3 py-1 text-xs font-bold rounded-lg transition-all ${(editingItem.type||'place')==='place'?'bg-white shadow-sm text-gray-900':'text-gray-500'}`}>景點</button>
                    <button onClick={()=>setEditingItem({...editingItem,type:'transport',transportSegments:editingItem.transportSegments?.length?editingItem.transportSegments:[emptySegment()]})} className={`px-3 py-1 text-xs font-bold rounded-lg transition-all ${editingItem.type==='transport'?'bg-white shadow-sm text-gray-900':'text-gray-500'}`}>交通</button>
                  </div>
                )}
              </div>
              <button onClick={()=>saveItineraryItem(editingItem)}
                disabled={editingItem.type==='transport'?!(editingItem.transportSegments?.[0]?.mode?.trim()):!editingItem.title?.trim()}
                className="bg-emerald-600 text-white font-bold px-5 py-2 rounded-xl text-sm disabled:opacity-40 active:scale-95 transition-transform">
                儲存
              </button>
            </div>

            {/* Modal body */}
            <div className="flex-1 overflow-y-auto px-5 py-5 space-y-4 pb-8">
              {/* Date / Time */}
              <div className="grid grid-cols-2 gap-3">
                <div>
                  <label className="block text-xs font-bold text-gray-500 mb-1.5">日期</label>
                  {tripDateRange.length > 0
                    ? <select className="w-full border border-gray-200 rounded-xl p-2.5 text-sm bg-gray-50 outline-none" value={editingItem.date||''} onChange={e=>setEditingItem({...editingItem,date:e.target.value})}>
                        <option value="">未定日期</option>
                        {tripDateRange.map((d,i)=>{const dt=new Date(d);return<option key={d} value={d}>第{i+1}天（{dt.getMonth()+1}/{dt.getDate()}）</option>;})}
                      </select>
                    : <input type="date" className="w-full border border-gray-200 rounded-xl p-2.5 text-sm bg-gray-50 outline-none" value={editingItem.date||''} onChange={e=>setEditingItem({...editingItem,date:e.target.value})}/>
                  }
                </div>
                <div>
                  <label className="block text-xs font-bold text-gray-500 mb-1.5">時間</label>
                  <input type="time" className="w-full border border-gray-200 rounded-xl p-2.5 text-sm bg-gray-50 outline-none" value={editingItem.time||''} onChange={e=>setEditingItem({...editingItem,time:e.target.value})}/>
                </div>
              </div>

              {/* Transport type */}
              {editingItem.type === 'transport' && (
                <div>
                  <label className="block text-xs font-bold text-gray-500 mb-1.5">交通段落</label>
                  <div className="space-y-3">
                    {(editingItem.transportSegments||[emptySegment()]).map((seg, si) => (
                      <div key={seg.id} className="bg-gray-50 border border-gray-200 rounded-2xl p-4 space-y-3">
                        <div className="flex items-center justify-between">
                          <span className="text-xs font-bold text-gray-500">第 {si+1} 段</span>
                          {si>0 && <button onClick={()=>setEditingItem({...editingItem,transportSegments:editingItem.transportSegments.filter((_,i)=>i!==si)})} className="text-gray-400 hover:text-red-400"><X size={14}/></button>}
                        </div>
                        <input type="text" placeholder="交通方式（高鐵、巴士…）" className="w-full border border-gray-200 rounded-xl p-2.5 text-sm bg-white outline-none focus:ring-2 focus:ring-emerald-400" value={seg.mode} onChange={e=>{const s=[...editingItem.transportSegments];s[si]={...s[si],mode:e.target.value};setEditingItem({...editingItem,transportSegments:s});}}/>
                        <div className="grid grid-cols-2 gap-2">
                          <div><label className="text-xs text-gray-400 block mb-1">搭車地點</label><input type="text" placeholder="台南火車站" className="w-full border border-gray-200 rounded-xl p-2 text-sm bg-white outline-none" value={seg.from||''} onChange={e=>{const s=[...editingItem.transportSegments];s[si]={...s[si],from:e.target.value};setEditingItem({...editingItem,transportSegments:s});}}/></div>
                          <div><label className="text-xs text-gray-400 block mb-1">下車地點</label><input type="text" placeholder="桃園機場" className="w-full border border-gray-200 rounded-xl p-2 text-sm bg-white outline-none" value={seg.to||''} onChange={e=>{const s=[...editingItem.transportSegments];s[si]={...s[si],to:e.target.value};setEditingItem({...editingItem,transportSegments:s});}}/></div>
                          <div><label className="text-xs text-gray-400 block mb-1">發車時間</label><input type="time" className="w-full border border-gray-200 rounded-xl p-2 text-sm bg-white outline-none" value={seg.departure||''} onChange={e=>{const s=[...editingItem.transportSegments];s[si]={...s[si],departure:e.target.value};setEditingItem({...editingItem,transportSegments:s});}}/></div>
                          <div><label className="text-xs text-gray-400 block mb-1">費用</label><input type="text" placeholder="1190" className="w-full border border-gray-200 rounded-xl p-2 text-sm bg-white outline-none" value={seg.price||''} onChange={e=>{const s=[...editingItem.transportSegments];s[si]={...s[si],price:e.target.value};setEditingItem({...editingItem,transportSegments:s});}}/></div>
                          <div><label className="text-xs text-gray-400 block mb-1">預估時間</label><input type="text" placeholder="30分鐘" className="w-full border border-gray-200 rounded-xl p-2 text-sm bg-white outline-none" value={seg.duration||''} onChange={e=>{const s=[...editingItem.transportSegments];s[si]={...s[si],duration:e.target.value};setEditingItem({...editingItem,transportSegments:s});}}/></div>
                          <div><label className="text-xs text-gray-400 block mb-1">購票截止</label><input type="date" className="w-full border border-gray-200 rounded-xl p-2 text-sm bg-white outline-none" value={seg.ticketDeadline||''} onChange={e=>{const s=[...editingItem.transportSegments];s[si]={...s[si],ticketDeadline:e.target.value};setEditingItem({...editingItem,transportSegments:s});}}/></div>
                        </div>
                        <input type="url" placeholder="購票連結 https://" className="w-full border border-gray-200 rounded-xl p-2.5 text-sm bg-white outline-none" value={seg.url||''} onChange={e=>{const s=[...editingItem.transportSegments];s[si]={...s[si],url:e.target.value};setEditingItem({...editingItem,transportSegments:s});}}/>
                        {/* Ticket reminder */}
                        <button onClick={()=>{
                          const s=[...editingItem.transportSegments];
                          s[si]={...s[si],needTicket:!s[si].needTicket};
                          setEditingItem({...editingItem,transportSegments:s});
                          if (!seg.needTicket) {
                            const mode=seg.mode||`第${si+1}段交通`; const date=editingItem.date||'';
                            const text=`${date?fmtDate(date)+' ':''}${mode}`.trim();
                            const exists=checklist.some(c=>c.itineraryId===editingItem.id&&c.segmentIdx===si);
                            if (!exists) setChecklist(prev=>[...prev,{id:crypto.randomUUID(),type:'ticket',text,checked:false,ticketDate:date,ticketMode:mode,ticketDeadline:seg.ticketDeadline||'',itineraryId:editingItem.id,segmentIdx:si}]);
                          } else {
                            setChecklist(prev=>prev.filter(c=>!(c.itineraryId===editingItem.id&&c.segmentIdx===si&&!c.checked)));
                          }
                        }}
                          className={`w-full flex items-center justify-between rounded-xl p-3 border transition-colors ${seg.needTicket?'bg-orange-50 border-orange-200 text-orange-700':'bg-gray-50 border-gray-200 text-gray-500'}`}>
                          <div className="flex items-center gap-2 text-sm font-semibold">
                            <Ticket size={16}/>加入購票提醒清單
                          </div>
                          <Plus size={16}/>
                        </button>
                      </div>
                    ))}
                    <button onClick={()=>setEditingItem({...editingItem,transportSegments:[...(editingItem.transportSegments||[]),emptySegment()]})}
                      className="w-full py-2.5 text-sm font-semibold text-gray-500 border border-dashed border-gray-300 rounded-xl hover:bg-gray-50 flex items-center justify-center gap-1">
                      <Plus size={14}/>新增一段
                    </button>
                  </div>
                  <div className="mt-3">
                    <label className="block text-xs font-bold text-gray-500 mb-1.5">備註（選填）</label>
                    <textarea className="w-full border border-gray-200 rounded-xl p-2.5 text-sm bg-gray-50 outline-none resize-none h-16 focus:ring-2 focus:ring-emerald-400" value={editingItem.notes||''} onChange={e=>setEditingItem({...editingItem,notes:e.target.value})}/>
                  </div>
                </div>
              )}

              {/* Place type */}
              {(editingItem.type||'place') === 'place' && (
                <>
                  <div>
                    <label className="block text-xs font-bold text-gray-500 mb-1.5">景點 / 標題 <span className="text-red-400">*</span></label>
                    <input type="text" placeholder="例如：奇美博物館" className="w-full border border-gray-200 rounded-xl p-2.5 text-sm bg-gray-50 outline-none focus:ring-2 focus:ring-emerald-400" value={editingItem.title||''} onChange={e=>setEditingItem({...editingItem,title:e.target.value})}/>
                  </div>
                  <div>
                    <label className="block text-xs font-bold text-gray-500 mb-1.5">地點</label>
                    <div className="relative"><MapPin size={15} className="absolute left-3 top-3 text-gray-400"/><input type="text" placeholder="店家名稱或地址" className="w-full border border-gray-200 rounded-xl p-2.5 pl-9 text-sm bg-gray-50 outline-none focus:ring-2 focus:ring-emerald-400" value={editingItem.location||''} onChange={e=>setEditingItem({...editingItem,location:e.target.value})}/></div>
                  </div>
                  <div>
                    <label className="block text-xs font-bold text-gray-500 mb-1.5">備註</label>
                    <textarea className="w-full border border-gray-200 rounded-xl p-2.5 text-sm bg-gray-50 h-16 outline-none resize-none focus:ring-2 focus:ring-emerald-400" placeholder="注意事項、小Tips…" value={editingItem.notes||''} onChange={e=>setEditingItem({...editingItem,notes:e.target.value})}/>
                  </div>

                  <button onClick={()=>setIsOptionalOpen(v=>!v)} className="w-full flex items-center justify-center gap-2 py-2.5 text-sm font-semibold text-gray-400 border border-dashed border-gray-300 rounded-xl hover:bg-gray-50">
                    {isOptionalOpen ? <><ChevronUp size={15}/>收起</>:<><Plus size={15}/>更多資訊（選填）</>}
                  </button>

                  {isOptionalOpen && (
                    <div className="space-y-4">
                      <div><label className="block text-xs font-bold text-gray-500 mb-1.5">營業時間</label><input type="text" placeholder="10:00-22:00" className="w-full border border-gray-200 rounded-xl p-2.5 text-sm bg-gray-50 outline-none focus:ring-2 focus:ring-emerald-400" value={editingItem.hours||''} onChange={e=>setEditingItem({...editingItem,hours:e.target.value})}/></div>
                      <div><label className="block text-xs font-bold text-gray-500 mb-1.5">官方網站</label><input type="url" placeholder="https://" className="w-full border border-gray-200 rounded-xl p-2.5 text-sm bg-gray-50 outline-none focus:ring-2 focus:ring-emerald-400" value={editingItem.website||''} onChange={e=>setEditingItem({...editingItem,website:e.target.value})}/></div>
                      <div>
                        <label className="block text-xs font-bold text-gray-700 mb-2 flex items-center gap-1"><ShoppingBag size={13}/>購物清單</label>
                        <div className="bg-gray-50 rounded-xl p-3 space-y-2">
                          {(editingItem.shoppingList||[]).map(s => (
                            <div key={s.id} className="flex items-center gap-2 bg-white border border-gray-100 rounded-lg p-2 text-sm"><span className="flex-1 truncate">{s.text}</span><button onClick={()=>delModalShop(s.id)} className="text-gray-300 hover:text-red-400"><X size={13}/></button></div>
                          ))}
                          <div className="flex gap-2"><input type="text" className="flex-1 border border-gray-200 rounded-lg px-2.5 py-1.5 text-sm outline-none focus:border-emerald-400 bg-white" placeholder="要買什麼…" value={modalNewShop} onChange={e=>setModalNewShop(e.target.value)} onKeyDown={e=>e.key==='Enter'&&addModalShop()}/><button onClick={addModalShop} className="bg-emerald-600 text-white px-3 py-1.5 rounded-lg text-sm font-bold">新增</button></div>
                        </div>
                      </div>
                      <div><label className="block text-xs font-bold text-gray-500 mb-1.5">門票資訊</label><input type="text" placeholder="票價或購票狀況" className="w-full border border-gray-200 rounded-xl p-2.5 text-sm bg-gray-50 outline-none focus:ring-2 focus:ring-emerald-400" value={editingItem.tickets||''} onChange={e=>setEditingItem({...editingItem,tickets:e.target.value})}/></div>
                    </div>
                  )}
                </>
              )}
            </div>
          </div>
        </div>
      )}

      {/* ── Settings modal ── */}
      {isSettingsOpen && (
        <div className="fixed inset-0 z-50 flex flex-col justify-end bg-black/30 backdrop-blur-sm max-w-md mx-auto left-1/2 -translate-x-1/2 w-full">
          <div onClick={()=>setIsSettingsOpen(false)} className="flex-1"/>
          <div className="bg-white/95 backdrop-blur-2xl w-full rounded-t-[28px] max-h-[90%] flex flex-col shadow-xl">
            <div className="flex items-center justify-between px-5 py-4 border-b border-gray-100">
              <button onClick={()=>setIsSettingsOpen(false)} className="p-2 -ml-2 text-gray-400 bg-gray-100 rounded-full"><X size={20}/></button>
              <span className="font-extrabold text-gray-900">系統設定</span>
              <div className="w-9"/>
            </div>
            <div className="flex-1 overflow-y-auto p-5 space-y-8 pb-10">
              {/* Users */}
              <div className="space-y-3">
                <div className="flex justify-between items-center">
                  <p className="font-bold text-gray-700 flex items-center gap-1.5 text-sm"><Users size={15} className="text-emerald-500"/>參與人員</p>
                  <button onClick={()=>setIsUsersLocked(!isUsersLocked)} className={`text-xs px-3 py-1 rounded-full font-bold ${isUsersLocked?'bg-gray-100 text-gray-500':'bg-red-50 text-red-500'}`}>
                    {isUsersLocked?<><Lock size={11} className="inline mr-1"/>鎖定</>:<><Unlock size={11} className="inline mr-1"/>編輯中</>}
                  </button>
                </div>
                <div className="flex flex-wrap gap-2">
                  {users.map((u,idx) => (
                    <div key={u} className={`px-3 py-1.5 rounded-full text-sm font-medium flex items-center gap-1.5 border ${idx===0?'bg-emerald-50 border-emerald-200 text-emerald-700':'bg-gray-50 border-gray-200 text-gray-700'}`}>
                      {idx===0&&<span className="text-amber-500 text-xs">👑</span>}
                      {editingUserId===u
                        ? <div className="flex items-center gap-1"><input autoFocus type="text" className="w-20 border-b border-emerald-400 bg-transparent outline-none text-center" value={editUserValue} onChange={e=>setEditUserValue(e.target.value)} onKeyDown={e=>e.key==='Enter'&&saveEditedUser(u)}/><button onClick={()=>saveEditedUser(u)} className="text-emerald-500"><Save size={13}/></button><button onClick={()=>setEditingUserId(null)} className="text-gray-400"><X size={13}/></button></div>
                        : <>{u}{!isUsersLocked&&<><button onClick={()=>{setEditingUserId(u);setEditUserValue(u);}} className="text-gray-300 hover:text-emerald-500 ml-1"><Edit2 size={13}/></button>{idx>0&&isOwner&&users.length>1&&<button onClick={()=>removeUser(u,idx)} className="text-gray-300 hover:text-red-400"><X size={13}/></button>}</>}</>
                      }
                    </div>
                  ))}
                </div>
                {!isUsersLocked && <div className="flex gap-2"><input type="text" value={newUser} onChange={e=>setNewUser(e.target.value)} onKeyDown={e=>e.key==='Enter'&&addUser()} placeholder="新增成員名字…" className="flex-1 border border-gray-200 rounded-xl px-3 py-2 text-sm bg-white outline-none focus:ring-2 focus:ring-emerald-400"/><button onClick={addUser} className="bg-emerald-600 text-white px-4 rounded-xl text-sm font-bold">新增</button></div>}
              </div>

              {/* Categories */}
              <div className="space-y-3">
                <p className="font-bold text-gray-700 flex items-center gap-1.5 text-sm"><Tag size={15} className="text-emerald-500"/>記帳分類</p>
                <div className="flex flex-wrap gap-2">
                  {categories.map(c => (
                    <div key={c} className="bg-emerald-50 text-emerald-700 border border-emerald-100 px-2.5 py-1 rounded-lg text-xs font-bold flex items-center gap-1">
                      {editingCatId===c
                        ? <><input autoFocus type="text" className="w-16 border-b border-emerald-400 bg-transparent outline-none text-center" value={editCatValue} onChange={e=>setEditCatValue(e.target.value)} onKeyDown={e=>e.key==='Enter'&&saveEditedCat(c)}/><button onClick={()=>saveEditedCat(c)} className="text-green-500"><Save size={11}/></button><button onClick={()=>setEditingCatId(null)} className="text-gray-400"><X size={11}/></button></>
                        : <>{c}<button onClick={()=>{setEditingCatId(c);setEditCatValue(c);}} className="text-emerald-300 hover:text-emerald-600 ml-0.5"><Edit2 size={11}/></button><button onClick={()=>removeCat(c)} className="text-emerald-300 hover:text-red-400"><X size={11}/></button></>
                      }
                    </div>
                  ))}
                </div>
                <div className="flex gap-2"><input type="text" value={newCategory} onChange={e=>setNewCategory(e.target.value)} onKeyDown={e=>e.key==='Enter'&&addCategory()} placeholder="新增分類…" className="flex-1 border border-gray-200 rounded-xl px-3 py-2 text-sm bg-white outline-none focus:ring-2 focus:ring-emerald-400"/><button onClick={addCategory} className="bg-gray-200 text-gray-700 px-3 py-2 rounded-xl text-sm font-bold">新增</button></div>
              </div>

              {/* Rates */}
              <div className="space-y-3">
                <div className="flex justify-between items-center">
                  <p className="font-bold text-gray-700 flex items-center gap-1.5 text-sm"><Globe size={15} className="text-emerald-500"/>匯率設定</p>
                  <span className="text-xs text-gray-400">基準：{baseCurrency}</span>
                </div>
                <p className="text-xs text-gray-400">範例：1 JPY = 0.21 TWD，輸入 0.21</p>
                <div className="space-y-2">
                  {Object.entries(rates).map(([c,r]) => (
                    <div key={c} className={`flex items-center gap-3 p-3 rounded-xl border text-sm ${c===baseCurrency?'bg-emerald-50 border-emerald-200':'bg-gray-50 border-gray-100'}`}>
                      {c===baseCurrency&&<Star size={12} className="text-amber-400 fill-amber-400 shrink-0"/>}
                      <span className={`font-bold ${c===baseCurrency?'text-emerald-700':'text-gray-600'} shrink-0`}>1 {c} =</span>
                      <input type="number" step="0.0001" value={r} onChange={e=>updateRate(c,e.target.value)} disabled={c===baseCurrency}
                        className={`flex-1 w-0 border-b text-right bg-transparent outline-none ${c===baseCurrency?'border-emerald-200 text-emerald-700':'border-gray-300'}`}/>
                      <span className="text-gray-500 text-xs">{baseCurrency}</span>
                      {c!==baseCurrency&&<><button onClick={()=>setBaseCurrency(c)} className="text-gray-300 hover:text-amber-400"><Star size={15}/></button><button onClick={()=>removeRate(c)} className="text-gray-300 hover:text-red-400"><X size={15}/></button></>}
                    </div>
                  ))}
                </div>
                <div className="flex gap-2">
                  <input type="text" value={newCurrency} onChange={e=>setNewCurrency(e.target.value.toUpperCase())} placeholder="幣別" maxLength="3" className="w-1/3 border border-gray-200 rounded-xl px-3 py-2 text-sm bg-white outline-none uppercase"/>
                  <input type="number" step="0.001" value={newRateValue} onChange={e=>setNewRateValue(e.target.value)} placeholder={`1幣=? ${baseCurrency}`} className="flex-1 border border-gray-200 rounded-xl px-3 py-2 text-sm bg-white outline-none"/>
                  <button onClick={addRate} className="bg-gray-200 text-gray-700 px-3 py-2 rounded-xl text-sm font-bold">新增</button>
                </div>
              </div>

              {/* Accommodations */}
              <div className="space-y-3">
                <p className="font-bold text-gray-700 flex items-center gap-1.5 text-sm"><Hotel size={15} className="text-teal-500"/>住宿設定</p>
                {accommodations.map((accom,idx) => (
                  <div key={idx} className="flex gap-2 items-center bg-teal-50 border border-teal-100 rounded-xl px-3 py-2.5">
                    <Hotel size={13} className="text-teal-500 shrink-0"/>
                    <div className="flex-1 min-w-0">
                      <p className="text-xs text-teal-600 font-bold">{accom.date?fmtDate(accom.date):'未設定'} 起</p>
                      <p className="text-sm font-medium text-gray-700 truncate">{accom.name}</p>
                    </div>
                    <button onClick={()=>setAccommodations(p=>p.filter((_,i)=>i!==idx))} className="text-gray-400 hover:text-red-400"><X size={15}/></button>
                  </div>
                ))}
                {!showAddAccom
                  ? <button onClick={()=>setShowAddAccom(true)} className="w-full py-2.5 text-sm text-teal-600 font-bold border border-dashed border-teal-300 rounded-xl hover:bg-teal-50 flex items-center justify-center gap-1"><Plus size={13}/>新增住宿</button>
                  : <div className="bg-white border border-teal-200 rounded-xl p-3 space-y-2">
                      {tripDateRange.length>0
                        ? <select className="w-full border rounded-lg p-2 text-sm bg-gray-50 outline-none" value={newAccomDate} onChange={e=>setNewAccomDate(e.target.value)}><option value="">選擇日期</option>{tripDateRange.map((d,i)=>{const dt=new Date(d);return<option key={d} value={d}>第{i+1}天 {dt.getMonth()+1}/{dt.getDate()}</option>;})}</select>
                        : <input type="date" className="w-full border rounded-lg p-2 text-sm" value={newAccomDate} onChange={e=>setNewAccomDate(e.target.value)}/>
                      }
                      <input type="text" placeholder="住宿名稱" className="w-full border rounded-lg p-2 text-sm bg-gray-50 outline-none focus:ring-2 focus:ring-teal-300" value={newAccomName} onChange={e=>setNewAccomName(e.target.value)}/>
                      <input type="text" placeholder="地址（供導航）" className="w-full border rounded-lg p-2 text-sm bg-gray-50 outline-none focus:ring-2 focus:ring-teal-300" value={newAccomLoc} onChange={e=>setNewAccomLoc(e.target.value)}/>
                      <div className="flex gap-2">
                        <button onClick={()=>{setShowAddAccom(false);setNewAccomName('');setNewAccomLoc('');setNewAccomDate('');}} className="flex-1 py-2 text-sm text-gray-500 bg-gray-100 rounded-lg">取消</button>
                        <button onClick={()=>{if(!newAccomName.trim())return; setAccommodations(p=>[...p,{date:newAccomDate,name:newAccomName.trim(),location:newAccomLoc.trim()||newAccomName.trim()}].sort((a,b)=>a.date.localeCompare(b.date))); setShowAddAccom(false);setNewAccomName('');setNewAccomLoc('');setNewAccomDate('');}} className="flex-1 py-2 text-sm text-white bg-teal-600 rounded-lg font-bold">新增</button>
                      </div>
                    </div>
                }
              </div>

              {/* Markdown import */}
              <div className="space-y-3">
                <p className="font-bold text-gray-700 text-sm">📥 匯入行程</p>
                <div className="flex gap-2">
                  <button onClick={()=>setIsMarkdownImportOpen(true)} className="flex-1 py-2.5 bg-emerald-600 text-white rounded-xl text-sm font-bold hover:bg-emerald-700">📋 貼上 Markdown</button>
                  <button onClick={downloadSampleMarkdown} className="px-4 py-2.5 bg-gray-100 text-gray-600 rounded-xl text-sm font-bold">📄 範例</button>
                </div>
              </div>

              <div className="text-center"><span className="text-xs text-gray-300 font-mono">v0.8.0</span></div>
            </div>
          </div>
        </div>
      )}

      {/* ── Share modal ── */}
      {isShareOpen && (
        <div className="fixed inset-0 z-50 flex flex-col justify-end bg-black/30 backdrop-blur-sm max-w-md mx-auto left-1/2 -translate-x-1/2 w-full">
          <div onClick={()=>{setIsShareOpen(false);setShareStatus('');}} className="flex-1"/>
          <div className="bg-white/95 backdrop-blur-2xl w-full rounded-t-[28px] max-h-[90%] flex flex-col shadow-xl">
            <div className="flex items-center justify-between px-5 py-4 border-b border-gray-100">
              <button onClick={()=>{setIsShareOpen(false);setShareStatus('');}} className="p-2 -ml-2 text-gray-400 bg-gray-100 rounded-full"><X size={20}/></button>
              <span className="font-extrabold text-gray-900">分享行程</span>
              <div className="w-9"/>
            </div>
            <div className="flex-1 overflow-y-auto p-5 space-y-6 pb-10">
              <div className="space-y-3">
                <p className="font-bold text-gray-700 text-sm">新增共享成員</p>
                <input type="email" placeholder="輸入對方的 Gmail…" value={newShareEmail} onChange={e=>{setNewShareEmail(e.target.value);setShareStatus('');}} className="w-full border border-gray-200 rounded-2xl px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-emerald-400 bg-gray-50"/>
                <div className="flex gap-2">
                  <button onClick={()=>setNewShareRole('viewer')} className={`flex-1 py-2.5 rounded-xl text-sm font-bold border-2 ${newShareRole==='viewer'?'border-emerald-500 bg-emerald-50 text-emerald-700':'border-gray-200 text-gray-500'}`}>👁 只能查看</button>
                  <button onClick={()=>setNewShareRole('editor')} className={`flex-1 py-2.5 rounded-xl text-sm font-bold border-2 ${newShareRole==='editor'?'border-emerald-500 bg-emerald-50 text-emerald-700':'border-gray-200 text-gray-500'}`}>✏️ 可以編輯</button>
                </div>
                <button onClick={addShareMember} className="w-full py-3 bg-emerald-600 text-white font-bold rounded-2xl active:scale-95 transition-transform">新增成員</button>
                {shareStatus && <p className="text-sm text-center text-gray-600">{shareStatus}</p>}
              </div>
              {shareEditors.length>0&&<div className="space-y-2"><p className="text-sm font-bold text-gray-700">✏️ 可編輯 ({shareEditors.length})</p>{shareEditors.map(eu=><div key={eu} className="flex justify-between items-center bg-emerald-50 border border-emerald-100 px-4 py-3 rounded-xl text-sm"><span className="text-emerald-800 font-medium truncate flex-1">{shareEmailMap[eu]||eu}</span><button onClick={()=>removeShareMember(eu,'editor')} className="text-gray-400 hover:text-red-400 ml-2"><X size={15}/></button></div>)}</div>}
              {shareViewers.length>0&&<div className="space-y-2"><p className="text-sm font-bold text-gray-700">👁 只能查看 ({shareViewers.length})</p>{shareViewers.map(vu=><div key={vu} className="flex justify-between items-center bg-gray-50 border border-gray-200 px-4 py-3 rounded-xl text-sm"><span className="text-gray-700 font-medium truncate flex-1">{shareEmailMap[vu]||vu}</span><button onClick={()=>removeShareMember(vu,'viewer')} className="text-gray-400 hover:text-red-400 ml-2"><X size={15}/></button></div>)}</div>}
              {shareEditors.length===0&&shareViewers.length===0&&<p className="text-center text-gray-400 text-sm py-4">尚未分享給任何人</p>}
              <p className="text-xs text-gray-400 text-center">對方需要先登入 App，才能看到被分享的行程</p>
            </div>
          </div>
        </div>
      )}

      {/* ── Markdown import modal ── */}
      {isMarkdownImportOpen && (
        <div className="fixed inset-0 z-50 flex flex-col justify-end bg-black/30 backdrop-blur-sm max-w-md mx-auto left-1/2 -translate-x-1/2 w-full">
          <div onClick={()=>{setIsMarkdownImportOpen(false);setMarkdownText('');setMarkdownStatus('');}} className="flex-1"/>
          <div className="bg-white/95 backdrop-blur-2xl w-full rounded-t-[28px] max-h-[85%] flex flex-col shadow-xl">
            <div className="flex items-center justify-between px-5 py-4 border-b border-gray-100">
              <button onClick={()=>{setIsMarkdownImportOpen(false);setMarkdownText('');setMarkdownStatus('');}} className="p-2 -ml-2 text-gray-400 bg-gray-100 rounded-full"><X size={20}/></button>
              <span className="font-extrabold text-gray-900">📋 匯入 Markdown</span>
              <div className="w-9"/>
            </div>
            <div className="flex-1 p-5 space-y-4 overflow-y-auto pb-10">
              <p className="text-xs text-gray-500">貼上 Markdown 格式的行程內容，會加到現有內容後面，不會覆蓋。</p>
              <textarea className="w-full h-56 border border-gray-200 rounded-2xl p-3 text-xs font-mono bg-gray-50 outline-none focus:ring-2 focus:ring-emerald-400 resize-none"
                placeholder={`## 2025-05-01\n- time: 09:00\n  title: 關西國際機場\n\n## 行前清單\n- [ ] 換日幣`}
                value={markdownText} onChange={e=>setMarkdownText(e.target.value)}/>
              {markdownStatus && <p className="text-sm text-center font-medium text-gray-700">{markdownStatus}</p>}
              <div className="flex gap-2">
                <button onClick={downloadSampleMarkdown} className="px-4 py-2.5 bg-gray-100 text-gray-600 rounded-xl text-sm font-bold">📄 下載範例</button>
                <button onClick={handleMarkdownImport} disabled={!markdownText.trim()} className="flex-1 py-2.5 bg-emerald-600 text-white rounded-xl text-sm font-bold disabled:opacity-40 active:scale-95 transition-transform">匯入</button>
              </div>
            </div>
          </div>
        </div>
      )}

      {/* ── Expense modals ── */}
      {addingExpenseFor && <ExpenseFormModal expenseItem={addingExpenseFor} users={users} rates={rates} baseCurrency={baseCurrency} categories={categories} onSave={saveExpense} onClose={()=>setAddingExpenseFor(null)}/>}
      {editingExpense   && <ExpenseFormModal key={`edit-${editingExpense.id}`} initialData={editingExpense} expenseItem={itinerary.find(i=>i.id===editingExpense.itineraryId)||{title:'一般花費'}} users={users} rates={rates} baseCurrency={baseCurrency} categories={categories} onSave={saveExpense} onClose={()=>setEditingExpense(null)}/>}
    </div>
  );
}
